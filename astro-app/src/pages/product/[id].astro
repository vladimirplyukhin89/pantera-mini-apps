---
// src/pages/product/[id].astro
// Страница отдельного товара

import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import BottomBar from '../../components/BottomBar';
import { getProductById } from '../../lib/products.js';

// Получаем ID товара из параметров маршрута
const { id } = Astro.params;
const productId = id ? parseInt(id) : null;

// Получаем товар по ID
let product = null;
if (productId && !isNaN(productId)) {
  product = getProductById(productId);
}

// Если товар не найден, возвращаем 404
if (!product) {
  return Astro.redirect('/catalog');
}
---

<Layout title={`${product.name} - Pantera Shop`}>
  <Header cartItemsCount={0} />
  
  <main class="main-content">
    <a href="/catalog" class="back-link">← Назад к каталогу</a>
    
    <div class="product-page">
      <div class="product-image-section">
        {product.image_url ? (
          <img 
            src={product.image_url} 
            alt={product.name}
            class="product-page-image"
            fetchpriority="high"
            loading="eager"
            decoding="async"

          />
        ) : (
          <div class="product-page-image-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5C21 3.9 20.1 3 19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19ZM8.5 13.5L11 16.51L14.5 12L19 18H5L8.5 13.5Z" fill="currentColor"/>
            </svg>
          </div>
        )}
      </div>
      
      <div class="product-details">
        {product.collection_name && (
          <div class="product-collection">{product.collection_name}</div>
        )}
        
        <h1 class="product-title">{product.name}</h1>
        
        {product.description && (
          <p class="product-description">{product.description}</p>
        )}
        
        {product.variants.length > 0 && (
          <div class="product-variants">
            <h2 class="variants-title">Выберите размер:</h2>
            <div class="variants-list">
              {product.variants.map(variant => (
                <div 
                  class={`variant-item ${variant.stock > 0 ? '' : 'out-of-stock'}`}
                  data-variant-id={variant.id}
                  data-variant-size={variant.size}
                  data-variant-price={variant.price}
                  data-variant-stock={variant.stock}
                >
                  <div class="variant-size">{variant.size}</div>
                  <div class="variant-price">{variant.price.toLocaleString('ru-RU')} ₽</div>
                  {variant.stock > 0 ? (
                    <div class="variant-stock">В наличии: {variant.stock} шт.</div>
                  ) : (
                    <div class="variant-stock out-of-stock-text">Нет в наличии</div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
        
        <div class="product-actions">
          <button class="add-to-cart-button" disabled>
            Добавить в корзину
          </button>
        </div>
      </div>
    </div>
  </main>

  <BottomBar client:load currentPath="/catalog" />
</Layout>

<script>
  // Client-side скрипт для выбора размера и добавления в корзину
  document.addEventListener('DOMContentLoaded', () => {
    const variantItems = document.querySelectorAll('.variant-item');
    const addToCartButton = document.querySelector('.add-to-cart-button') as HTMLButtonElement | null;
    let selectedVariant: { id: number; size: string; price: number; stock: number; } | null = null;

    variantItems.forEach(item => {
      const variantElement = item as HTMLElement;
      const stock = parseInt(variantElement.dataset.variantStock || '0');
      
      if (stock <= 0) return; // Пропускаем варианты без товара
      
      variantElement.addEventListener('click', () => {
        // Убираем выделение с других вариантов
        variantItems.forEach(v => v.classList.remove('selected'));
        
        // Добавляем выделение выбранному варианту
        variantElement.classList.add('selected');
        
        // Сохраняем выбранный вариант
        selectedVariant = {
          id: parseInt(variantElement.dataset.variantId || '0'),
          size: variantElement.dataset.variantSize || '',
          price: parseFloat(variantElement.dataset.variantPrice || '0'),
          stock: stock
        };
        
        // Активируем кнопку добавления в корзину
        if (addToCartButton) {
          addToCartButton.disabled = false;
          addToCartButton.textContent = `Добавить в корзину (${selectedVariant.size})`;
        }
      });
    });
    
    // Обработка добавления в корзину (пока заглушка, будет реализовано на этапе 5)
    if (addToCartButton) {
      addToCartButton.addEventListener('click', () => {
        if (!selectedVariant) return;
        
        // TODO: Реализовать добавление в корзину на этапе 5
        alert(`Товар будет добавлен в корзину (размер ${selectedVariant.size})`);
      });
    }
  });
</script>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 5rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--tg-theme-button-color, var(--color-accent-blue));
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .product-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-image-section {
    width: 100%;
  }

  .product-page-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

  .product-page-image-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-border-gray);
    border-radius: 12px;
    color: var(--color-text-gray);
  }

  .product-details {
    width: 100%;
  }

  .product-collection {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-gray);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.75rem;
  }

  .product-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--tg-theme-text-color, var(--color-text-dark));
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .product-description {
    font-size: 1rem;
    color: var(--tg-theme-hint-color, var(--color-text-gray));
    margin: 0 0 2rem 0;
    line-height: 1.6;
  }

  .product-variants {
    margin-bottom: 2rem;
  }

  .variants-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--tg-theme-text-color, var(--color-text-dark));
    margin: 0 0 1rem 0;
  }

  .variants-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.75rem;
  }

  .variant-item {
    padding: 1rem;
    border: 2px solid var(--color-border-gray);
    border-radius: 8px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background-color: var(--color-bg-white);
  }

  .variant-item:hover:not(.out-of-stock) {
    border-color: var(--tg-theme-button-color, var(--color-accent-blue));
    background-color: var(--tg-theme-secondary-bg-color, rgba(0, 0, 0, 0.05));
  }

  .variant-item.selected {
    border-color: var(--tg-theme-button-color, var(--color-accent-blue));
    background-color: var(--tg-theme-button-color, var(--color-accent-blue));
    color: var(--tg-theme-button-text-color, var(--color-white));
  }

  .variant-item.out-of-stock {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .variant-size {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .variant-price {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .variant-stock {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  .variant-item.selected .variant-stock {
    opacity: 1;
  }

  .out-of-stock-text {
    color: var(--color-red-accent);
  }

  .product-actions {
    margin-top: 2rem;
  }

  .add-to-cart-button {
    width: 100%;
    padding: 1rem 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--tg-theme-button-text-color, var(--color-white));
    background-color: var(--tg-theme-button-color, var(--color-accent-blue));
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .add-to-cart-button:hover:not(:disabled) {
    opacity: 0.9;
  }

  .add-to-cart-button:active:not(:disabled) {
    transform: scale(0.98);
  }

  .add-to-cart-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background-color: var(--color-border-gray);
    color: var(--color-text-gray);
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .product-page {
      flex-direction: row;
      align-items: flex-start;
      gap: 2rem;
    }

    .product-image-section {
      flex: 1;
      max-width: 400px;
    }

    .product-details {
      flex: 1;
    }

    .product-title {
      font-size: 2rem;
    }

    .variants-list {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .main-content {
      max-width: 1280px;
      padding: 2.5rem 2rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .product-page {
      gap: 3rem;
    }

    .product-title {
      font-size: 2.5rem;
    }
  }
</style>

