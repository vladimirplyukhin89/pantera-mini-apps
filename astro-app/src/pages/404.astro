---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import HeroSection from '../components/HeroSection.astro';

Astro.response.status = 404;

const bg404 = '/images/jpg/404.jpg';
const site = Astro.site ?? new URL('https://pantera-boxing.ru');
const og404 = new URL(bg404, site).href;
---

<Layout
  title="Страница не найдена — Pantera"
  description="Такой страницы нет. Вернитесь на главную Pantera или откройте галерею и команду."
  image={og404}
  noindex
>
  <BottomBar slot="bottom-bar" />
  <main class="main-content">
    <HeroSection
      title="404"
      description="Такой страницы нет, братик — на главную?"
      ctaLink="/"
      bgMobile={bg404}
      bgDesktop={bg404}
    />
    <Header />
  </main>
</Layout>

<style>
  .main-content {
    position: relative;
    flex: 1;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    height: 100vh;
  }
</style>
