---
// src/pages/contacts.astro
// Страница контактов

import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import { ImGrin } from "react-icons/im";
---

<Layout title="Контакты - Pantera Shop">
  <Header cartItemsCount={0} />
  
  <main class="main-content">
    <div class="wrapper-text">
      <h1 class="page-title">Как нам шумануть</h1>
      <ImGrin className="smile-icon" size={40} />
    </div>
    
    <section class="contacts-section">
      <div class="contact-item">
        <h2 class="contact-label">Адрес</h2>
        <p class="contact-value">Укажите адрес зала</p>
      </div>

      <div class="contact-item">
        <h2 class="contact-label">Телефон</h2>
        <a href="tel:+79991234567" class="contact-value contact-link">+7 (999) 123-45-67</a>
      </div>

      <div class="contact-item">
        <h2 class="contact-label">Email</h2>
        <a href="mailto:info@pantera-box.com" class="contact-value contact-link">info@pantera-box.com</a>
      </div>
    </section>
  </main>

  <BottomBar client:load currentPath="/contacts" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 2rem 1.5rem;
    padding-top: calc(var(--header-height) + 2rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 5rem; /* Отступ для bottom bar */
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-icon-contacts);
    margin-bottom: 2rem;
    text-align: center;
    display: inline-block;
  }

  .wrapper-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .smile-icon {
    fill: var(--color-icon-home);
  }

  .contacts-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-item {
    padding: 1.5rem;
    background-color: var(--tg-theme-secondary-bg-color, #f5f5f5);
    border-radius: 8px;
  }

  .contact-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--tg-theme-hint-color, #999999);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .contact-value {
    font-size: 1.125rem;
    color: var(--tg-theme-text-color, #000000);
    margin: 0;
  }

  .contact-link {
    color: var(--tg-theme-link-color, #3390ec);
    text-decoration: none;
  }

  .contact-link:hover {
    text-decoration: underline;
  }
</style>

