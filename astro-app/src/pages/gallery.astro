---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import PhotoGrid from '../components/PhotoGrid/PhotoGrid';
import ClubValues from '../components/ClubValues.astro';
import EventsSlider from '../components/EventsSlider/EventsSlider';
import {
  fetchStrapi,
  strapiMedia,
  isVideoMedia,
  getAccentColor,
  type StrapiGalleryPhoto,
  type StrapiClubValue,
  type StrapiEvent,
} from '../lib/strapi';
import { optimizeStrapiImageResponsive } from '../lib/strapiImages';
import { Image } from 'astro:assets';

// ─── Gallery photos ──────────────────────────────────────
type GalleryPhoto = {
  src: string;
  srcSet: string;
  sizes: string;
  alt: string;
  variant?: 'tall' | 'wide';
};

let galleryPhotos: GalleryPhoto[] = [];
try {
  const raw = await fetchStrapi<StrapiGalleryPhoto[]>(
    'gallery-photos?populate=image&sort=order:asc'
  );
  const built = await Promise.all(
    raw.map(async (p) => {
      const remoteSrc = strapiMedia(p.image?.url);
      const variant = p.variant === 'tall' || p.variant === 'wide' ? p.variant : undefined;
      const common = {
        alt: p.alt || '',
        ...(variant ? { variant } : {}),
      };
      if (!remoteSrc) return null;
      const optimized = await optimizeStrapiImageResponsive(
        remoteSrc,
        [320, 480, 640, 800],
        '(max-width: 480px) 50vw, (max-width: 1024px) 33vw, 360px',
        'gallery:grid'
      );
      return { ...optimized, ...common };
    })
  );
  galleryPhotos = built.filter((x): x is GalleryPhoto => x !== null && x !== undefined);
} catch (e) {
  console.error('Strapi gallery-photos:', e);
}

// ─── Club values ─────────────────────────────────────────

let clubValues: { photo: string; title: string; description: string; accent?: string }[] = [];
try {
  const raw = await fetchStrapi<StrapiClubValue[]>('club-values?populate=photo&sort=order:asc');
  clubValues = raw.map((v) => ({
    photo: strapiMedia(v.photo?.url),
    title: v.title,
    description: v.description,
    accent: getAccentColor(v.accent_color),
  }));
} catch (e) {
  console.error('Strapi club-values:', e);
}

// ─── Events ──────────────────────────────────────────────

interface SliderEvent {
  id: string;
  title: string;
  teaser: string;
  date: string;
  statusCode: 'planned' | 'past';
  media: { type: 'image' | 'video'; src: string; srcSet?: string; sizes?: string; alt?: string }[];
  videoCover?: string;
  videoCoverSrcSet?: string;
  videoCoverSizes?: string;
  accentIndex: number;
}

let planned: SliderEvent[] = [];
let past: SliderEvent[] = [];
try {
  const raw = await fetchStrapi<StrapiEvent[]>('events?populate=*&sort=order:asc');
  const all = await Promise.all(
    raw.map(async (ev): Promise<SliderEvent> => {
      const media = await Promise.all(
        (ev.media || []).map(async (m) => {
          const isVideo = isVideoMedia(m);
          const remoteSrc = strapiMedia(m.url);
          const optimized =
            !isVideo && remoteSrc
              ? await optimizeStrapiImageResponsive(
                  remoteSrc,
                  [240, 320, 480, 640],
                  '(max-width: 480px) 80vw, (max-width: 1024px) 44vw, 360px',
                  `gallery:event:${ev.slug || ev.documentId}`
                )
              : { src: remoteSrc, srcSet: '', sizes: '' };

          return {
            type: isVideo ? ('video' as const) : ('image' as const),
            src: optimized.src,
            ...(optimized.srcSet ? { srcSet: optimized.srcSet } : {}),
            ...(optimized.sizes ? { sizes: optimized.sizes } : {}),
            alt: m.alternativeText || '',
          };
        })
      );

      const videoCoverRemote = ev.video_cover?.url ? strapiMedia(ev.video_cover.url) : '';
      const videoCoverOptimized = videoCoverRemote
        ? await optimizeStrapiImageResponsive(
            videoCoverRemote,
            [240, 320, 480, 640],
            '(max-width: 480px) 80vw, (max-width: 1024px) 44vw, 360px',
            `gallery:event:video-cover:${ev.slug || ev.documentId}`
          )
        : null;

      return {
        id: ev.slug || ev.documentId,
        title: ev.title,
        teaser: ev.teaser || '',
        date: ev.date_label || '',
        statusCode: ev.statusCode ?? ev.statusPlan ?? ev.status ?? 'past',
        media,
        videoCover: videoCoverOptimized?.src,
        ...(videoCoverOptimized?.srcSet ? { videoCoverSrcSet: videoCoverOptimized.srcSet } : {}),
        ...(videoCoverOptimized?.sizes ? { videoCoverSizes: videoCoverOptimized.sizes } : {}),
        accentIndex: ev.accent_index ?? 0,
      };
    })
  );
  planned = all.filter((e) => e.statusCode === 'planned');
  past = all.filter((e) => e.statusCode === 'past');
} catch (e) {
  console.error('Strapi events:', e);
}

const isGalleryEmpty =
  !planned.length && !past.length && !clubValues.length && !galleryPhotos.length;
---

<Layout
  title="Галерея - Pantera"
  description="События Pantera, фотогалерея клуба и то, зачем мы собираемся — бокс и люди."
>
  <BottomBar slot="bottom-bar" currentPath="/gallery" />
  <Header />

  <main class:list={['main-content', { 'main-content--empty': isGalleryEmpty }]}>
    {
      isGalleryEmpty && (
        <div class="no-content">
          <p class="no-content-text">Какие-то проблемки с данными, уже шаманим</p>
          <Image
            src="/images/svg/white_logo.svg"
            alt="Pantera"
            class="shop-logo"
            loading="eager"
            width={260}
            height={260}
          />
        </div>
      )
    }

    {
      (planned.length > 0 || past.length > 0) && (
        <>
          <span class="section-label">События</span>
          <section class="events-section">
            <EventsSlider client:idle planned={planned} past={past} />
          </section>
        </>
      )
    }

    {
      clubValues.length > 0 && (
        <>
          <span class="section-label">Наши ценности</span>
          <section class="club-section">
            <ClubValues values={clubValues} />
          </section>
        </>
      )
    }

    {
      galleryPhotos.length > 0 && (
        <>
          <span class="section-label">О нашем клубе</span>
          <section class="club-section">
            <div class="section-header">
              <h1 class="section-title">
                Место, где <span class="accent-word">характер</span> закаляется
              </h1>
              <p class="section-subtitle">Если я упал - не радуйся, я просто отдохнул и встал</p>
            </div>
            <PhotoGrid client:visible photos={galleryPhotos} perPage={8} />
          </section>
        </>
      )
    }
  </main>
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 0.75rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
    --section-label-gap: 1.25rem;
    --section-stack-gap: 2.5rem;
  }

  .main-content--empty {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 0;
  }

  .section-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-gallery);
  }

  .no-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
    padding: 1rem 0;
  }

  .no-content-text {
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-text-cream-alpha);
    max-width: 26rem;
    margin: 0;
  }

  .shop-logo {
    display: block;
    width: min(200px, 72vw);
    height: auto;
  }

  /* Подписи, идущие сразу под <main>: одинаковый отступ сверху и снизу */
  .main-content > .section-label {
    display: block;
    margin-block: var(--section-label-gap);
  }

  .main-content > .section-label:first-child {
    margin-top: 0;
  }

  .section-header .section-label {
    margin: 0 0 0.75rem;
  }

  .club-section {
    margin-bottom: var(--section-stack-gap);
  }

  .club-section:last-child {
    margin-bottom: 0;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-cream);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .accent-word {
    color: var(--color-red-accent);
    font-style: italic;
  }

  .events-section {
    --events-slider-margin-top: 0;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7rem;
      padding-top: calc(var(--header-height) + 0.75rem);
    }
    .no-content-text {
      font-size: 1.125rem;
    }

    .shop-logo {
      width: min(240px, 50vw);
    }

    .section-title {
      font-size: 2.5rem;
    }

    .section-subtitle {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 769px) {
    .main-content {
      padding: 2rem 1.5rem 7rem;
      padding-top: calc(var(--header-height) + 1.5rem);
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem 8.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .no-content-text {
      font-size: 1.1875rem;
      max-width: 32rem;
    }

    .section-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
