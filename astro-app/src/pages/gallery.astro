---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import PhotoGrid from '../components/PhotoGrid/PhotoGrid';
import ClubValues from '../components/ClubValues.astro';
import EventsSlider from '../components/EventsSlider/EventsSlider';
import {
  fetchStrapi,
  strapiMedia,
  isVideoMedia,
  getAccentColor,
  type StrapiGalleryPhoto,
  type StrapiClubValue,
  type StrapiEvent,
} from '../lib/strapi';
import { optimizeStrapiImage800 } from '../lib/strapiImages';

// ─── Gallery photos ──────────────────────────────────────
type GalleryPhoto = {
  src: string;
  alt: string;
  variant?: 'tall' | 'wide';
};

let galleryPhotos: GalleryPhoto[] = [];
try {
  const raw = await fetchStrapi<StrapiGalleryPhoto[]>(
    'gallery-photos?populate=image&sort=order:asc'
  );
  const built = await Promise.all(
    raw.map(async (p) => {
      const remoteSrc = strapiMedia(p.image?.url);
      const variant = p.variant === 'tall' || p.variant === 'wide' ? p.variant : undefined;
      const common = {
        alt: p.alt || '',
        ...(variant ? { variant } : {}),
      };
      if (!remoteSrc) return null;
      return { src: await optimizeStrapiImage800(remoteSrc, 'gallery'), ...common };
    })
  );
  galleryPhotos = built.filter((x): x is GalleryPhoto => x !== null && x !== undefined);
} catch (e) {
  console.error('Strapi gallery-photos:', e);
}

// ─── Club values ─────────────────────────────────────────

let clubValues: { photo: string; title: string; description: string; accent?: string }[] = [];
try {
  const raw = await fetchStrapi<StrapiClubValue[]>('club-values?populate=photo&sort=order:asc');
  clubValues = raw.map((v) => ({
    photo: strapiMedia(v.photo?.url),
    title: v.title,
    description: v.description,
    accent: getAccentColor(v.accent_color),
  }));
} catch (e) {
  console.error('Strapi club-values:', e);
}

// ─── Events ──────────────────────────────────────────────

interface SliderEvent {
  id: string;
  title: string;
  teaser: string;
  date: string;
  statusCode: 'planned' | 'past';
  media: { type: 'image' | 'video'; src: string; alt?: string }[];
  videoCover?: string;
  accentIndex: number;
}

let planned: SliderEvent[] = [];
let past: SliderEvent[] = [];
try {
  const raw = await fetchStrapi<StrapiEvent[]>('events?populate=*&sort=order:asc');
  const all = raw.map(
    (ev): SliderEvent => ({
      id: ev.slug || ev.documentId,
      title: ev.title,
      teaser: ev.teaser || '',
      date: ev.date_label || '',
      statusCode: ev.statusCode ?? ev.statusPlan ?? ev.status ?? 'past',
      media: (ev.media || []).map((m) => ({
        type: isVideoMedia(m) ? ('video' as const) : ('image' as const),
        src: strapiMedia(m.url),
        alt: m.alternativeText || '',
      })),
      videoCover: ev.video_cover?.url ? strapiMedia(ev.video_cover.url) : undefined,
      accentIndex: ev.accent_index ?? 0,
    })
  );
  planned = all.filter((e) => e.statusCode === 'planned');
  past = all.filter((e) => e.statusCode === 'past');
} catch (e) {
  console.error('Strapi events:', e);
}
---

<Layout
  title="Галерея - Pantera"
  description="События Pantera, фотогалерея клуба и то, зачем мы собираемся — бокс и люди."
>
  <Header />

  <main class="main-content">
    {
      (planned.length > 0 || past.length > 0) && (
        <>
          <span class="section-label">События</span>
          <section class="events-section">
            <EventsSlider client:idle planned={planned} past={past} />
          </section>
        </>
      )
    }

    {
      clubValues.length > 0 && (
        <>
          <span class="section-label">Наши ценности</span>
          <section class="club-section">
            <ClubValues values={clubValues} />
          </section>
        </>
      )
    }

    {
      galleryPhotos.length > 0 && (
        <>
          <span class="section-label">О нашем клубе</span>
          <section class="club-section">
            <div class="section-header">
              <h1 class="section-title">
                Место, где <span class="accent-word">характер</span> закаляется
              </h1>
              <p class="section-subtitle">Если я упал - не радуйся, я просто шнурки проверял</p>
            </div>
            <PhotoGrid client:visible photos={galleryPhotos} perPage={8} />
          </section>
        </>
      )
    }
  </main>

  <BottomBar currentPath="/gallery" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
    --section-label-gap: 1.25rem;
    --section-stack-gap: 2.5rem;
  }

  .section-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-gallery);
  }

  /* Подписи, идущие сразу под <main>: одинаковый отступ сверху и снизу */
  .main-content > .section-label {
    display: block;
    margin-block: var(--section-label-gap);
  }

  .main-content > .section-label:first-child {
    margin-top: 0;
  }

  .section-header .section-label {
    margin: 0 0 0.75rem;
  }

  .club-section {
    margin-bottom: var(--section-stack-gap);
  }

  .club-section:last-child {
    margin-bottom: 0;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-cream);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .accent-word {
    color: var(--color-red-accent);
    font-style: italic;
  }

  .events-section {
    --events-slider-margin-top: 0;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .section-title {
      font-size: 2.5rem;
    }

    .section-subtitle {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem 8.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .section-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
