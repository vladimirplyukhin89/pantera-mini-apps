---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import AthleteCard from '../components/AthleteCard.astro';
import ContactSection from '../components/ContactSection.astro';
import {
  fetchStrapi,
  strapiMedia,
  getSocialIcon,
  type StrapiAthlete,
  type StrapiContactInfo,
  type StrapiSocialLink,
} from '../lib/strapi';
import { optimizeStrapiImage800 } from '../lib/strapiImages';
import { Image } from 'astro:assets';

const [athletesRaw, contactPropsInitial, socialsRaw] = await Promise.all([
  (async (): Promise<StrapiAthlete[]> => {
    try {
      const raw = await fetchStrapi<StrapiAthlete[]>('athletes?populate=photo&sort=order:asc');
      return Array.isArray(raw) ? raw : [];
    } catch (e) {
      console.error('Strapi athletes:', e);
      return [];
    }
  })(),
  (async (): Promise<Record<string, unknown>> => {
    try {
      const raw = await fetchStrapi<StrapiContactInfo>('contact-info');
      if (!raw) return {};
      const contacts = [];
      if (raw.address) contacts.push({ icon: '📍', label: 'Адрес', value: raw.address });
      if (raw.phone)
        contacts.push({
          icon: '📞',
          label: 'Телефон',
          value: raw.phone,
          href: `tel:${raw.phone.replace(/\D/g, '')}`,
        });
      if (raw.email)
        contacts.push({
          icon: '✉️',
          label: 'Email',
          value: raw.email,
          href: `mailto:${raw.email}`,
        });
      if (raw.schedule) contacts.push({ icon: '⏰', label: 'График', value: raw.schedule });

      return {
        ...(raw.title ? { title: raw.title } : {}),
        ...(raw.subtitle ? { subtitle: raw.subtitle } : {}),
        contacts,
        ...(raw.quote ? { quote: raw.quote } : {}),
      };
    } catch (e) {
      console.error('Strapi contact-info:', e);
      return {};
    }
  })(),
  (async (): Promise<StrapiSocialLink[] | null> => {
    try {
      const raw = await fetchStrapi<StrapiSocialLink[]>('social-links?sort=order:asc');
      return Array.isArray(raw) ? raw : null;
    } catch (e) {
      console.error('Strapi social-links:', e);
      return null;
    }
  })(),
]);

type AthleteRow = StrapiAthlete & { photoSrc: string };
const athletes: AthleteRow[] = await Promise.all(
  athletesRaw.map(async (a) => ({
    ...a,
    photoSrc: await optimizeStrapiImage800(strapiMedia(a.photo?.url), `athlete (${a.name})`),
  }))
);

let contactProps: Record<string, unknown> = contactPropsInitial;
if (socialsRaw && socialsRaw.length > 0) {
  contactProps = {
    ...contactProps,
    socials: socialsRaw.map((s) => ({
      name: s.name,
      url: s.url,
      icon: s.icon || getSocialIcon(s.name),
    })),
  };
}

const isSportsmenEmpty = athletes.length === 0 && (socialsRaw == null || socialsRaw.length === 0);
---

<Layout
  title="Наша команда - Pantera"
  description="Команда Pantera: люди клуба. Контакты клуба и соцсети — всегда на связи."
>
  <BottomBar slot="bottom-bar" currentPath="/sportsmen" />
  <Header />

  <main class:list={['main-content', { 'main-content--empty': isSportsmenEmpty }]}>
    {
      isSportsmenEmpty && (
        <div class="no-content">
          <p class="no-content-text">Какие-то проблемки с данными, уже шаманим</p>
          <Image
            src="/images/svg/white_logo.svg"
            alt="Pantera"
            class="shop-logo"
            loading="eager"
            width={260}
            height={260}
          />
        </div>
      )
    }

    {
      !isSportsmenEmpty &&
        (athletes.length > 0 ? (
          <div class="page-header">
            <span class="page-label">Команда</span>
            <h1 class="page-title">Наши люди</h1>
            <p class="page-subtitle">Люди, которые делают Pantera — ведь это не только зал</p>
          </div>
        ) : (
          <div class="page-header">
            <p class="page-subtitle">Какие-то проблемки с данными, уже шаманим</p>
          </div>
        ))
    }

    {
      athletes.map((a) => (
        <section class="athlete-section">
          <AthleteCard
            photo={a.photoSrc}
            label={a.label}
            name={a.name}
            quote={a.quote}
            stats={a.stats}
            badge={a.badge}
          />
        </section>
      ))
    }

    {
      !isSportsmenEmpty && socialsRaw != null && socialsRaw.length > 0 && (
        <section class="socials-section">
          <span class="page-label">Контакты</span>
          <ContactSection {...contactProps} />
        </section>
      )
    }
  </main>
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
    --section-label-gap: 1.25rem;
    --section-stack-gap: 2.5rem;
  }

  .main-content--empty {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 0;
  }

  .no-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
    padding: 1rem 0;
  }

  .no-content-text {
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-text-cream-alpha);
    max-width: 26rem;
    margin: 0;
  }

  .shop-logo {
    display: block;
    width: min(200px, 72vw);
    height: auto;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-contacts);
    display: block;
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .athlete-section {
    margin-bottom: 1.5rem;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .no-content-text {
      font-size: 1.125rem;
    }

    .shop-logo {
      width: min(240px, 50vw);
    }

    .page-title {
      font-size: 2.75rem;
    }

    .page-subtitle {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem 8.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .no-content-text {
      font-size: 1.1875rem;
      max-width: 32rem;
    }

    .page-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
