---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import AthleteCard from '../components/AthleteCard.astro';
import ContactSection from '../components/ContactSection.astro';
---

<Layout title="Наши спортсмены - Pantera">
  <Header />

  <main class="main-content">
    <div class="page-header">
      <span class="page-label">Команда</span>
      <h1 class="page-title">Наши спортсмены</h1>
      <p class="page-subtitle">
        Люди, которые делают Pantera — это не только зал
      </p>
    </div>

    <section class="athlete-section">
      <AthleteCard />
    </section>

    <ContactSection />
  </main>

  <BottomBar client:load currentPath="/sportsmen" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-contacts);
    display: block;
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .athlete-section {
    margin-bottom: 1rem;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .page-title {
      font-size: 2.75rem;
    }

    .page-subtitle {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .page-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
