---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import AthleteCard from '../components/AthleteCard.astro';
import ContactSection from '../components/ContactSection.astro';
import {
  fetchStrapi,
  strapiMedia,
  getSocialIcon,
  type StrapiAthlete,
  type StrapiContactInfo,
  type StrapiSocialLink,
} from '../lib/strapi';

// ─── Athletes ────────────────────────────────────────────

let athletes: StrapiAthlete[] = [];
try {
  athletes = await fetchStrapi<StrapiAthlete[]>('athletes?populate=photo&sort=order:asc');
} catch (e) {
  console.error('Strapi athletes:', e);
}

// ─── Contact info ────────────────────────────────────────

let contactProps: Record<string, unknown> = {};
try {
  const raw = await fetchStrapi<StrapiContactInfo>('contact-info');
  if (raw) {
    const contacts = [];
    if (raw.address) contacts.push({ icon: '📍', label: 'Адрес', value: raw.address });
    if (raw.phone)
      contacts.push({
        icon: '📞',
        label: 'Телефон',
        value: raw.phone,
        href: `tel:${raw.phone.replace(/\D/g, '')}`,
      });
    if (raw.email)
      contacts.push({ icon: '✉️', label: 'Email', value: raw.email, href: `mailto:${raw.email}` });
    if (raw.schedule) contacts.push({ icon: '⏰', label: 'График', value: raw.schedule });

    contactProps = {
      ...(raw.title ? { title: raw.title } : {}),
      ...(raw.subtitle ? { subtitle: raw.subtitle } : {}),
      contacts,
      ...(raw.quote ? { quote: raw.quote } : {}),
    };
  }
} catch (e) {
  console.error('Strapi contact-info:', e);
}

// ─── Social links ────────────────────────────────────────

try {
  const raw = await fetchStrapi<StrapiSocialLink[]>('social-links?sort=order:asc');
  if (raw.length > 0) {
    contactProps.socials = raw.map((s) => ({
      name: s.name,
      url: s.url,
      icon: s.icon || getSocialIcon(s.name),
    }));
  }
} catch (e) {
  console.error('Strapi social-links:', e);
}
---

<Layout title="Наши спортсмены - Pantera">
  <Header />

  <main class="main-content">
    {
      athletes.length > 0 && (
        <div class="page-header">
          <span class="page-label">Команда</span>
          <h1 class="page-title">Наши спортсмены</h1>
          <p class="page-subtitle">Люди, которые делают Pantera — это не только зал</p>
        </div>
      )
    }

    {
      athletes.map((a) => (
        <section class="athlete-section">
          <AthleteCard
            photo={strapiMedia(a.photo?.url)}
            label={a.label}
            name={a.name}
            quote={a.quote}
            stats={a.stats}
            badge={a.badge}
          />
        </section>
      ))
    }

    <span class="page-label">Контакты</span>
    <ContactSection {...contactProps} />
  </main>

  <BottomBar client:load currentPath="/sportsmen" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-contacts);
    display: block;
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .athlete-section {
    margin-bottom: 1.5rem;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7.5rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .page-title {
      font-size: 2.75rem;
    }

    .page-subtitle {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem 8.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .page-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
