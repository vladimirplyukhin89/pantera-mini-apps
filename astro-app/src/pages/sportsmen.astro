---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import { ImGrin } from 'react-icons/im';
---

<Layout title="Наши спортсмены - Pantera">
  <Header />

  <main class="main-content">
    <div class="wrapper-text">
      <h1 class="page-title">Наши спортсмены</h1>
      <ImGrin className="smile-icon" size={40} />
    </div>

    <section class="sportsmen-section">
      <div class="sportsmen-item">
        <h2 class="sportsmen-label">Адрес зала</h2>
        <p class="sportsmen-value">Укажите адрес зала</p>
      </div>

      <div class="sportsmen-item">
        <h2 class="sportsmen-label">Телефон</h2>
        <a href="tel:+79991234567" class="sportsmen-value sportsmen-link">+7 (999) 123-45-67</a>
      </div>

      <div class="sportsmen-item">
        <h2 class="sportsmen-label">Email</h2>
        <a href="mailto:info@pantera-box.com" class="sportsmen-value sportsmen-link"
          >info@pantera-box.com</a
        >
      </div>
    </section>
  </main>

  <BottomBar client:load currentPath="/sportsmen" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 2rem 1.5rem;
    padding-top: calc(var(--header-height) + 2rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 5rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-icon-contacts);
    margin-bottom: 2rem;
    text-align: center;
    display: inline-block;
  }

  .wrapper-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .smile-icon {
    fill: var(--color-icon-home);
  }

  .sportsmen-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sportsmen-item {
    padding: 1.5rem;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
  }

  .sportsmen-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-gray);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .sportsmen-value {
    font-size: 1.125rem;
    color: var(--color-text-cream);
    margin: 0;
  }

  .sportsmen-link {
    color: var(--color-accent-blue);
    text-decoration: none;
  }

  .sportsmen-link:hover {
    text-decoration: underline;
  }
</style>
