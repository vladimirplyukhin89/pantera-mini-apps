---
// src/pages/cart.astro
// Страница корзины с полным функционалом

import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import { ImSad, ImHeartBroken } from "react-icons/im";
---

<Layout title="Корзина - Pantera Shop">
  <Header />
  
  <main class="main-content">
    <div class="wrapper-text">
      <h1 class="page-title">Корзина</h1>
      <ImHeartBroken className="heart-icon" size={40} />
    </div>

    <div id="cart-container">
      <!-- Загрузка... -->
      <div id="cart-loading" class="loading-message">
        Загрузка корзины...
      </div>

      <!-- Пустая корзина -->
      <div id="cart-empty" class="empty-cart" style="display: none;">
        <div class="wrapper-text">
          <p class="empty-message">Корзина пуста</p>
          <ImSad size={40} />
        </div>
        <a href="/catalog" class="btn-primary">Перейти в каталог</a>
      </div>

      <!-- Товары корзины -->
      <div id="cart-items" class="cart-items" style="display: none;">
        <div id="cart-items-list" class="cart-items-list">
          <!-- Товары будут добавлены через JavaScript -->
        </div>

        <div class="cart-summary">
          <div class="summary-row">
            <span class="summary-label">Итого:</span>
            <span id="cart-total" class="summary-value">0 ₽</span>
          </div>
          <button id="checkout-btn" class="btn-checkout">Оформить заказ</button>
        </div>
      </div>

      <!-- Ошибка -->
      <div id="cart-error" class="error-message" style="display: none;">
        <p>Ошибка при загрузке корзины</p>
        <button id="retry-btn" class="btn-primary">Повторить</button>
      </div>
    </div>
  </main>

  <BottomBar client:load currentPath="/cart" />
</Layout>

<script>
  // Функция для получения telegram_user_id
  function getTelegramUserId() {
    if (typeof window === 'undefined') {
      return null;
    }

    try {
      // Проверяем наличие Telegram WebApp SDK
      const tg = (window as any).Telegram;
      if (tg?.WebApp?.initDataUnsafe?.user?.id) {
        return String(tg.WebApp.initDataUnsafe.user.id);
      }

      // Fallback для разработки (можно использовать тестовый ID)
      const testUserId = localStorage.getItem('test_telegram_user_id');
      if (testUserId) {
        return testUserId;
      }
      
      // Или использовать дефолтный тестовый ID для разработки
      return '123456789'; // Для разработки
    } catch (error) {
      console.error('Ошибка при получении telegram_user_id:', error);
      return null;
    }
  }

  // Получаем элементы DOM после загрузки страницы
  let cartContainer: HTMLElement | null = null;
  let cartLoading: HTMLElement | null = null;
  let cartEmpty: HTMLElement | null = null;
  let cartItems: HTMLElement | null = null;
  let cartItemsList: HTMLElement | null = null;
  let cartTotal: HTMLElement | null = null;
  let cartError: HTMLElement | null = null;
  let checkoutBtn: HTMLButtonElement | null = null;
  let retryBtn: HTMLButtonElement | null = null;

  let currentCart: any = null;

  // Инициализация элементов DOM
  function initElements() {
    cartContainer = document.getElementById('cart-container');
    cartLoading = document.getElementById('cart-loading');
    cartEmpty = document.getElementById('cart-empty');
    cartItems = document.getElementById('cart-items');
    cartItemsList = document.getElementById('cart-items-list');
    cartTotal = document.getElementById('cart-total');
    cartError = document.getElementById('cart-error');
    checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement | null;
    retryBtn = document.getElementById('retry-btn') as HTMLButtonElement | null;
  }

  // Функция для загрузки корзины
  async function loadCart() {
    const telegramUserId = getTelegramUserId();
    
    if (!telegramUserId) {
      showError('Не удалось определить пользователя. Пожалуйста, откройте приложение в Telegram.');
      return;
    }

    // Показываем загрузку
    showLoading();

    try {
      const response = await fetch(`/api/cart?telegram_user_id=${telegramUserId}`);
      
      if (!response.ok) {
        throw new Error(`Ошибка ${response.status}: ${response.statusText}`);
      }

      const cart = await response.json();
      currentCart = cart;

      // Сохраняем в localStorage
      localStorage.setItem('cart_items_count', String(cart.items?.length || 0));
      localStorage.setItem('cart_data', JSON.stringify(cart));

      // Обновляем UI
      if (cart.items && cart.items.length > 0) {
        displayCartItems(cart);
      } else {
        showEmpty();
      }

      // Отправляем событие обновления корзины
      window.dispatchEvent(new CustomEvent('cartUpdated'));

    } catch (error) {
      console.error('Ошибка при загрузке корзины:', error);
      showError(error.message || 'Не удалось загрузить корзину');
    }
  }

  // Функция для отображения товаров корзины
  function displayCartItems(cart: any) {
    if (!cartItemsList) return;
    
    cartItemsList.innerHTML = '';

    cart.items.forEach((item: any) => {
      const itemElement = createCartItemElement(item);
      cartItemsList!.appendChild(itemElement);
    });

    // Обновляем общую сумму
    updateTotal(cart.items);

    // Показываем товары
    hideAll();
    if (cartItems) {
      cartItems.style.display = 'block';
    }
  }

  // Функция для создания элемента товара
  function createCartItemElement(item: any) {
    const div = document.createElement('div');
    div.className = 'cart-item';
    div.dataset.itemId = String(item.id);

    const itemTotal = item.price * item.quantity;
    const imageUrl = item.product_image_url || '/images/placeholder.jpg';
    const productName = item.product_name || 'Товар';

    div.innerHTML = `
      <div class="cart-item-image">
        <img src="${imageUrl}" alt="${productName}" />
      </div>
      <div class="cart-item-info">
        <h3 class="cart-item-name">${productName}</h3>
        <p class="cart-item-size">Размер: ${item.size}</p>
        <p class="cart-item-price">${item.price} ₽ × ${item.quantity} = ${itemTotal} ₽</p>
        <div class="cart-item-controls">
          <button class="btn-quantity" data-action="decrease" data-item-id="${item.id}">−</button>
          <span class="quantity-value">${item.quantity}</span>
          <button class="btn-quantity" data-action="increase" data-item-id="${item.id}">+</button>
          <button class="btn-delete" data-item-id="${item.id}" title="Удалить">🗑️</button>
        </div>
      </div>
    `;

    // Добавляем обработчики событий
    const decreaseBtn = div.querySelector('[data-action="decrease"]') as HTMLButtonElement | null;
    const increaseBtn = div.querySelector('[data-action="increase"]') as HTMLButtonElement | null;
    const deleteBtn = div.querySelector('.btn-delete') as HTMLButtonElement | null;

    if (decreaseBtn) {
      decreaseBtn.addEventListener('click', () => updateQuantity(item.id, item.quantity - 1));
    }
    if (increaseBtn) {
      increaseBtn.addEventListener('click', () => updateQuantity(item.id, item.quantity + 1));
    }
    if (deleteBtn) {
      deleteBtn.addEventListener('click', () => deleteItem(item.id));
    }

    return div;
  }

  // Функция для обновления количества товара
  async function updateQuantity(itemId, newQuantity) {
    if (newQuantity <= 0) {
      deleteItem(itemId);
      return;
    }

    const telegramUserId = getTelegramUserId();
    if (!telegramUserId) {
      alert('Не удалось определить пользователя');
      return;
    }

    try {
      const response = await fetch(`/api/cart/items/${itemId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ quantity: newQuantity }),
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.message || 'Ошибка при обновлении количества');
      }

      // Перезагружаем корзину
      await loadCart();

    } catch (error) {
      console.error('Ошибка при обновлении количества:', error);
      alert(error.message || 'Не удалось обновить количество товара');
    }
  }

  // Функция для удаления товара
  async function deleteItem(itemId) {
    if (!confirm('Удалить товар из корзины?')) {
      return;
    }

    const telegramUserId = getTelegramUserId();
    if (!telegramUserId) {
      alert('Не удалось определить пользователя');
      return;
    }

    try {
      const response = await fetch(`/api/cart/items/${itemId}`, {
        method: 'DELETE',
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.message || 'Ошибка при удалении товара');
      }

      // Перезагружаем корзину
      await loadCart();

    } catch (error) {
      console.error('Ошибка при удалении товара:', error);
      alert(error.message || 'Не удалось удалить товар');
    }
  }

  // Функция для обновления общей суммы
  function updateTotal(items: any[]) {
    if (!cartTotal) return;
    const total = items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    cartTotal.textContent = `${total} ₽`;
  }

  // Функции для управления отображением
  function showLoading() {
    if (!cartLoading) return;
    hideAll();
    cartLoading.style.display = 'block';
  }

  function showEmpty() {
    if (!cartEmpty) return;
    hideAll();
    cartEmpty.style.display = 'block';
  }

  function showError(message: string) {
    if (!cartError) return;
    hideAll();
    cartError.style.display = 'block';
    const errorText = cartError.querySelector('p');
    if (errorText) {
      errorText.textContent = message || 'Ошибка при загрузке корзины';
    }
  }

  function hideAll() {
    if (cartLoading) cartLoading.style.display = 'none';
    if (cartEmpty) cartEmpty.style.display = 'none';
    if (cartItems) cartItems.style.display = 'none';
    if (cartError) cartError.style.display = 'none';
  }

  // Инициализация при загрузке страницы
  document.addEventListener('DOMContentLoaded', () => {
    initElements();
    
    // Обработчик кнопки "Оформить заказ"
    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', () => {
        if (currentCart && currentCart.items && currentCart.items.length > 0) {
          window.location.href = '/checkout';
        } else {
          alert('Корзина пуста');
        }
      });
    }

    // Обработчик кнопки "Повторить"
    if (retryBtn) {
      retryBtn.addEventListener('click', () => {
        loadCart();
      });
    }

    // Загружаем корзину при загрузке страницы
    loadCart();

    // Слушаем события обновления корзины
    window.addEventListener('cartUpdated', () => {
      loadCart();
    });
  });
</script>

<style>
  .main-content {
    flex: 1;
    padding: 2rem 1.5rem;
    padding-top: calc(var(--header-height) + 2rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 5rem; /* Отступ для bottom bar */
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-icon-fire);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .wrapper-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .heart-icon {
    fill: var(--color-icon-heart);
  }

  .loading-message,
  .empty-message,
  .error-message {
    text-align: center;
    padding: 2rem 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-white);
  }

  .empty-cart {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 3rem 1rem;
  }

  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background-color: var(--tg-theme-bg-color, rgba(255, 255, 255, 0.1));
    border-radius: 12px;
    border: 1px solid var(--tg-theme-hint-color, rgba(255, 255, 255, 0.1));
  }

  .cart-item-image {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 8px;
    overflow: hidden;
  }

  .cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-item-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-white);
    margin: 0;
  }

  .cart-item-size {
    font-size: 1rem;
    color: var(--tg-theme-hint-color, var(--color-text-gray));
    margin: 0;
  }

  .cart-item-price {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-white);
    margin: 0;
  }

  .cart-item-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .btn-quantity {
    width: 32px;
    height: 32px;
    border: 1px solid var(--tg-theme-hint-color, rgba(255, 255, 255, 0.3));
    background-color: var(--tg-theme-bg-color, rgba(255, 255, 255, 0.1));
    color: var(--color-text-white);
    border-radius: 6px;
    font-size: 1.25rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .btn-quantity:hover {
    background-color: var(--tg-theme-button-color, var(--color-accent-blue));
    border-color: var(--tg-theme-button-color, var(--color-accent-blue));
  }

  .btn-quantity:active {
    transform: scale(0.95);
  }

  .quantity-value {
    min-width: 40px;
    text-align: center;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-white);
  }

  .btn-delete {
    width: 32px;
    height: 32px;
    border: none;
    background-color: transparent;
    cursor: pointer;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }

  .btn-delete:hover {
    transform: scale(1.2);
  }

  .btn-delete:active {
    transform: scale(0.9);
  }

  .cart-summary {
    padding: 1.5rem;
    background-color: var(--tg-theme-bg-color, rgba(255, 255, 255, 0.1));
    border-radius: 12px;
    border: 1px solid var(--tg-theme-hint-color, rgba(255, 255, 255, 0.1));
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .summary-label {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-white);
  }

  .summary-value {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-icon-fire);
  }

  .btn-checkout,
  .btn-primary {
    width: 100%;
    padding: 1rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--tg-theme-button-text-color, var(--color-white));
    background-color: var(--tg-theme-button-color, var(--color-accent-blue));
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-checkout:hover,
  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .btn-checkout:active,
  .btn-primary:active {
    transform: translateY(0);
  }

  .error-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
  }

  @media (min-width: 481px) {
    .cart-item {
      padding: 1.5rem;
    }

    .cart-item-image {
      width: 120px;
      height: 120px;
    }
  }
</style>
