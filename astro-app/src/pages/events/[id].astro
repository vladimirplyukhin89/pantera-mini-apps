---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header.astro';
import BottomBar from '../../components/BottomBar/BottomBar';
import EventMediaGallery from '../../components/EventMediaGallery/EventMediaGallery';
import {
  fetchStrapi,
  fetchAllEventsForStaticPaths,
  strapiMedia,
  isVideoMedia,
  parseEmbedVideoIframeSrc,
  renderBlocks,
  type StrapiEvent,
} from '../../lib/strapi';
import { isPastEventPage } from '../../lib/eventAt';
import { absoluteImageForOg, optimizeStrapiImage800 } from '../../lib/strapiImages';

export async function getStaticPaths() {
  try {
    // `pagination[pageSize]` не должен превышать `rest.maxLimit` в Strapi (в репо — 100), иначе API может ответить 400 и маршруты событий не сгенерируются.
    const events = await fetchAllEventsForStaticPaths();
    return events.filter((e) => e.slug).map((e) => ({ params: { id: e.slug } }));
  } catch (e) {
    console.error('Strapi events list for SSG:', e);
    return [];
  }
}

const { id } = Astro.params;

const accentColors = [
  'var(--color-red-accent)',
  'var(--color-turquoise-panther)',
  'var(--color-icon-home)',
  'var(--color-icon-gallery)',
];

let event: StrapiEvent | null = null;
try {
  const raw = await fetchStrapi<StrapiEvent[]>(
    `events?filters[slug][$eq]=${encodeURIComponent(id!)}&populate=*`
  );
  if (raw.length > 0) event = raw[0];
} catch (e) {
  console.error('Strapi event fetch:', e);
}

if (!event) {
  return Astro.redirect('/gallery');
}

const accent = accentColors[(event.accent_index ?? 0) % 4];
const isPast = isPastEventPage(event, new Date());
const bodyHtml = renderBlocks(event.body);

const embedIframeSrc = parseEmbedVideoIframeSrc(event.embed_video_url);

const siteUrl = Astro.site ?? new URL('https://pantera-boxing.ru');

const coverRaw = event.video_cover?.url ? strapiMedia(event.video_cover.url) : '';
const videoCoverUrl = coverRaw
  ? await optimizeStrapiImage800(coverRaw, `event cover (${id})`)
  : undefined;

const media = await Promise.all(
  (event.media || []).map(async (m) => {
    const remoteSrc = strapiMedia(m.url);
    const video = isVideoMedia(m);
    const src = video ? remoteSrc : await optimizeStrapiImage800(remoteSrc, `event media (${id})`);
    return {
      type: video ? ('video' as const) : ('image' as const),
      src,
      alt: m.alternativeText || '',
      ...(video && videoCoverUrl ? { poster: videoCoverUrl } : {}),
    };
  })
);

const teaserPlain = event.teaser
  .replace(/<[^>]*>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
const metaDescription =
  teaserPlain.length > 160
    ? `${teaserPlain.slice(0, 157)}…`
    : teaserPlain || `${event.title} — событие боксёрского клуба Pantera, Тюмень.`;

let metaImage: string | undefined;
if (videoCoverUrl) metaImage = absoluteImageForOg(videoCoverUrl, siteUrl);
else {
  const firstImg = media.find((item) => item.type === 'image');
  if (firstImg?.src) metaImage = absoluteImageForOg(firstImg.src, siteUrl);
}
---

<Layout title={`${event.title} — Pantera`} description={metaDescription} image={metaImage}>
  <Header />

  <main class="main-content">
    <a href="/gallery" class="back-link" data-astro-prefetch="viewport">← Назад к галерее</a>

    <div class="event-header">
      <div class="event-meta">
        <span class="event-badge" style={`--accent: ${accent}`}>
          {isPast ? 'Прошедшее' : 'Запланировано'}
        </span>
        <span class="event-date">{event.date_label}</span>
      </div>
      <h1 class="event-title">{event.title}</h1>
    </div>

    {
      embedIframeSrc && (
        <div class="embed-video-wrap">
          <div class="embed-video-inner">
            <iframe
              class="embed-video-iframe"
              src={embedIframeSrc}
              title="Видео события"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      )
    }

    {
      media.length > 0 && (
        <div class="media-section">
          <EventMediaGallery client:load media={media} />
          {media.length > 1 && <div class="media-hint">← листай →</div>}
        </div>
      )
    }

    <div class="event-body" set:html={bodyHtml} />

    <a href="/gallery" class="bottom-back" data-astro-prefetch="viewport">← Все события</a>
  </main>

  <BottomBar client:load transition:persist transition:name="bottom-bar" currentPath="/gallery" />
</Layout>

<style define:vars={{ accent }}>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-cream-alpha);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-text-cream);
  }

  .event-header {
    margin-bottom: 2rem;
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .event-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    background: var(--accent);
    color: var(--color-text-cream);
  }

  .event-date {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-gray);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .event-emoji {
    font-size: 3.5rem;
    line-height: 1;
    display: block;
    margin-bottom: 0.75rem;
  }

  .event-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.15;
  }

  .embed-video-wrap {
    margin: 0 -1rem 2rem;
  }

  .embed-video-inner {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 0.75rem;
    background: rgba(0, 0, 0, 0.35);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .embed-video-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .media-section {
    margin: 0 -1rem 2rem;
  }

  .media-hint {
    text-align: center;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-gray);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 0.75rem;
    opacity: 0.5;
  }

  .event-body {
    margin-bottom: 2.5rem;
  }

  .event-body :global(p) {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .event-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .event-body :global(strong) {
    color: var(--color-text-cream);
    font-weight: 700;
  }

  .event-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1rem 0;
    font-style: italic;
    color: var(--color-text-cream-alpha);
  }

  .bottom-back {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--accent);
    border-radius: 2rem;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .bottom-back:hover {
    background: var(--accent);
    color: var(--color-text-cream);
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7.5rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .event-title {
      font-size: 2.75rem;
    }

    .embed-video-wrap {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
    }

    .media-section {
      margin-left: -1.5rem;
      margin-right: -1.5rem;
    }
  }

  @media (min-width: 769px) {
    .main-content {
      padding: 2.5rem 1.5rem 8.5rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
    }

    .event-title {
      font-size: 3rem;
    }

    .event-body :global(p) {
      font-size: 1.05rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
