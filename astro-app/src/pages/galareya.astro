---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import PhotoGrid from '../components/PhotoGrid/PhotoGrid';
import ClubValues from '../components/ClubValues.astro';
import EventsSlider from '../components/EventsSlider/EventsSlider';
import {
  fetchStrapi,
  strapiMedia,
  getAccentColor,
  parseEventsSliderBg,
  type StrapiGalleryPhoto,
  type StrapiClubValue,
  type StrapiEvent,
  type StrapiGallerySettings,
} from '../lib/strapi';
import type { BgVariant } from '../components/EventsSlider/EventsSlider';

// ─── Gallery photos ──────────────────────────────────────

let galleryPhotos: { src: string; alt: string; variant?: 'tall' | 'wide' }[] = [];
try {
  const raw = await fetchStrapi<StrapiGalleryPhoto[]>('gallery-photos?populate=image&sort=order:asc');
  galleryPhotos = raw.map((p) => ({
    src: strapiMedia(p.image?.url),
    alt: p.alt || '',
    ...(p.variant && p.variant !== 'default' ? { variant: p.variant } : {}),
  }));
} catch (e) {
  console.error('Strapi gallery-photos:', e);
}

// ─── Club values ─────────────────────────────────────────

let clubValues: { photo: string; title: string; description: string; accent?: string }[] = [];
try {
  const raw = await fetchStrapi<StrapiClubValue[]>('club-values?populate=photo&sort=order:asc');
  clubValues = raw.map((v) => ({
    photo: strapiMedia(v.photo?.url),
    title: v.title,
    description: v.description,
    accent: getAccentColor(v.accent_color),
  }));
} catch (e) {
  console.error('Strapi club-values:', e);
}

// ─── Events ──────────────────────────────────────────────

interface SliderEvent {
  id: string;
  title: string;
  teaser: string;
  date: string;
  statusCode: 'planned' | 'past';
  media: { type: 'image' | 'video'; src: string; alt?: string }[];
  accentIndex: number;
}

let planned: SliderEvent[] = [];
let past: SliderEvent[] = [];
try {
  const raw = await fetchStrapi<StrapiEvent[]>('events?populate=media&sort=order:asc');
  const all = raw.map((ev): SliderEvent => ({
    id: ev.slug || ev.documentId,
    title: ev.title,
    teaser: ev.teaser || '',
    date: ev.date_label || '',
    statusCode: ev.statusCode ?? ev.statusPlan ?? ev.status ?? 'past',
    media: (ev.media || []).map((m) => ({
      type: 'image' as const,
      src: strapiMedia(m.url),
      alt: m.alternativeText || '',
    })),
    accentIndex: ev.accent_index ?? 0,
  }));
  planned = all.filter((e) => e.statusCode === 'planned');
  past = all.filter((e) => e.statusCode === 'past');
} catch (e) {
  console.error('Strapi events:', e);
}

// ─── Фон слайдера событий (Strapi Single Type `gallery-settings`, поле `events_slider_bg`) ─

let eventsSliderBg: BgVariant = 'glow';
try {
  const settings = await fetchStrapi<StrapiGallerySettings>('gallery-settings');
  const parsed = parseEventsSliderBg(settings?.events_slider_bg);
  if (parsed) eventsSliderBg = parsed;
} catch (e) {
  console.error('Strapi gallery-settings:', e);
}
---

<Layout title="Галерея - Pantera">
  <Header />

  <main class="main-content">

    <span class="section-label">События</span>
    {(planned.length > 0 || past.length > 0) && (
      <section class="events-section">
        <EventsSlider client:load planned={planned} past={past} bgVariant={eventsSliderBg} />
      </section>
    )}

    <span class="section-label">Наши ценности</span>
    {clubValues.length > 0 && (
      <section class="club-section">
        <ClubValues values={clubValues} />
      </section>
    )}

    {galleryPhotos.length > 0 && (
      <section class="club-section">
        <div class="section-header">
          <span class="section-label">О нашем клубе</span>
          <h1 class="section-title">
            Место, где <span class="accent-word">характер</span> закаляется
          </h1>
        </div>
        <PhotoGrid client:load photos={galleryPhotos} perPage={8} />
      </section>
    )}

  </main>

  <BottomBar client:load currentPath="/galareya" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 7.5rem;
    --section-label-gap: 1.25rem;
    --section-stack-gap: 2.5rem;
  }

  .section-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-icon-gallery);
  }

  /* Подписи, идущие сразу под <main>: одинаковый отступ сверху и снизу */
  .main-content > .section-label {
    display: block;
    margin-block: var(--section-label-gap);
  }

  .main-content > .section-label:first-child {
    margin-top: 0;
  }

  /* Подпись внутри блока с заголовком — свои интервалы, без дублирования margin-block */
  .section-header .section-label {
    margin: 0 0 0.75rem;
  }

  .club-section {
    margin-bottom: var(--section-stack-gap);
  }

  .club-section:last-child {
    margin-bottom: 0;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-cream);
    margin-bottom: 0.75rem;
  }

  .accent-word {
    color: var(--color-red-accent);
    font-style: italic;
  }

  /* Убираем лишний верхний отступ у слайдера: на странице уже есть .section-label */
  .events-section {
    --events-slider-margin-top: 0;
  }

  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem 7rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .section-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .main-content {
      max-width: 1100px;
      padding: 2.5rem 1.5rem 8rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .section-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1440px) {
    .main-content {
      max-width: 1200px;
    }
  }
</style>
