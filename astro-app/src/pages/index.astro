---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import HeroSection from '../components/HeroSection.astro';
import { fetchStrapi, strapiMedia, type StrapiHero } from '../lib/strapi';

const PAGE_TITLE = 'Бокс для взрослых в Тюмени — Pantera';

const SEO_FALLBACK_DESCRIPTION =
  'Бокс для взрослых в Тюмени — клуб Pantera: тренировки, события и атмосфера, которую не перепутать.';

function finalizeMetaDescription(plain: string): string {
  let t = plain.replace(/\s+/g, ' ').trim();
  if (!t) return SEO_FALLBACK_DESCRIPTION;
  if (!/тюмен/i.test(t)) {
    t = `${t} — Тюмень.`;
  }
  if (t.length > 160) {
    return `${t.slice(0, 157)}…`;
  }
  return t;
}

let heroProps: Record<string, string> = {};
let metaDescription = SEO_FALLBACK_DESCRIPTION;
let metaImage: string | undefined;
try {
  const raw = await fetchStrapi<StrapiHero>('hero?populate=*');
  if (raw) {
    heroProps = {
      ...(raw.title ? { title: raw.title } : {}),
      ...(raw.description ? { description: raw.description } : {}),
      ...(raw.cta_link ? { ctaLink: raw.cta_link } : {}),
      ...(raw.bg_mobile?.url ? { bgMobile: strapiMedia(raw.bg_mobile.url) } : {}),
      ...(raw.bg_desktop?.url ? { bgDesktop: strapiMedia(raw.bg_desktop.url) } : {}),
    };
    if (raw.description) {
      const plain = raw.description
        .replace(/<[^>]*>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      if (plain) metaDescription = finalizeMetaDescription(plain);
    }
    const og = raw.bg_desktop?.url || raw.bg_mobile?.url;
    if (og) metaImage = strapiMedia(og);
  }
} catch (e) {
  console.error('Strapi hero:', e);
}
---

<Layout title={PAGE_TITLE} description={metaDescription} image={metaImage}>
  <BottomBar slot="bottom-bar" currentPath="/" />
  <main class="main-content">
    <HeroSection {...heroProps} />
    <Header />
  </main>
</Layout>

<style>
  .main-content {
    position: relative;
    flex: 1;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    height: 100vh;
  }
</style>
