---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBarIsland.astro';
import HeroSection from '../components/HeroSection.astro';
import { fetchStrapi, strapiMedia, type StrapiHero } from '../lib/strapi';

let heroProps: Record<string, string> = {};
let metaDescription =
  'Pantera — боксёрский клуб в Тюмени: тренировки, события и атмосфера, которую не перепутать.';
let metaImage: string | undefined;
try {
  const raw = await fetchStrapi<StrapiHero>('hero?populate=*');
  if (raw) {
    heroProps = {
      ...(raw.title ? { title: raw.title } : {}),
      ...(raw.description ? { description: raw.description } : {}),
      ...(raw.cta_link ? { ctaLink: raw.cta_link } : {}),
      ...(raw.bg_mobile?.url ? { bgMobile: strapiMedia(raw.bg_mobile.url) } : {}),
      ...(raw.bg_desktop?.url ? { bgDesktop: strapiMedia(raw.bg_desktop.url) } : {}),
    };
    if (raw.description) {
      const plain = raw.description
        .replace(/<[^>]*>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      if (plain) metaDescription = plain.length > 160 ? `${plain.slice(0, 157)}…` : plain;
    }
    const og = raw.bg_desktop?.url || raw.bg_mobile?.url;
    if (og) metaImage = strapiMedia(og);
  }
} catch (e) {
  console.error('Strapi hero:', e);
}
---

<Layout title="Главная - Pantera" description={metaDescription} image={metaImage}>
  <main class="main-content">
    <HeroSection {...heroProps} />
    <Header />
  </main>

  <BottomBar currentPath="/" />
</Layout>

<style>
  .main-content {
    position: relative;
    flex: 1;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    height: 100vh;
  }
</style>
