---
// src/pages/catalog.astro
// Страница каталога товаров

import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import BottomBar from '../components/BottomBar/BottomBar';
import ProductCard from '../components/ProductCard.astro';
import SizeFilter from '../components/SizeFilter/SizeFilter';
import { getAllProducts } from '@/lib/products.js';
import { ImNeutral, ImWink } from 'react-icons/im';

// Получаем все товары с сервера (server-side)
const products = getAllProducts();

// Получаем все доступные размеры из товаров
const allSizes = new Set<string>();
products.forEach(product => {
  product.variants.forEach(variant => {
    allSizes.add(variant.size);
  });
});
const availableSizes = Array.from(allSizes).sort();
---

<Layout title="Каталог - Pantera Shop">
  <Header cartItemsCount={0} />
  
  <main class="main-content">
    <div class="wrapper-text">
      <h1 class="page-title">Это всё тебе, родной</h1>
      <ImWink className="heart-icon" size={40} />
    </div>
    
    {availableSizes.length > 0 && (
      <SizeFilter client:load availableSizes={availableSizes} />
    )}
    
    {products.length > 0 ? (
      <div class="products-grid">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="wrapper-text">
        <span class="empty-message">Ща наберу шефу где товар</span>
        <ImNeutral size={40} />
      </div>
    )}
  </main>

  <BottomBar client:load currentPath="/catalog" />
</Layout>

<style>
  .main-content {
    flex: 1;
    padding: 1.5rem 1rem;
    padding-top: calc(var(--header-height) + 1.5rem);
    max-width: 100%;
    margin: 0 auto;
    padding-bottom: 5rem; /* Отступ для bottom bar */
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-icon-catalog);
    margin-bottom: 1.5rem;
    text-align: center;
    display: inline-block;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
  }

  .wrapper-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }


  .empty-message {
    color: var(--tg-theme-hint-color, var(--color-text-gray));
    text-align: center;
    padding: 2rem 0;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text-white);
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .main-content {
      padding: 2rem 1.5rem;
      padding-top: calc(var(--header-height) + 2rem);
    }

    .page-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 600px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .main-content {
      max-width: 1280px;
      padding: 2.5rem 2rem;
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .page-title {
      font-size: 3rem;
    }

    .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
</style>

