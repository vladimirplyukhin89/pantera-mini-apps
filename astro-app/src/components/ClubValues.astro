---
import '../styles/section-backgrounds.css';

interface ValueItem {
  photo: string;
  title: string;
  description: string;
  accent?: string;
}

interface Props {
  values?: ValueItem[];
  /** Shared `u-bg-*` panel variants from section-backgrounds.css */
  bgVariant?: 'glow' | 'diagonal' | 'mesh' | 'salad';
}

const { values, bgVariant = 'salad' } = Astro.props;
---

<section class:list={['values-section', 'u-bg-panel', `u-bg-${bgVariant}`]}>
  <div class="values-header">
    <h2 class="values-title">
      Не просто тренировки — <span class="values-accent">добрая морось</span>
    </h2>
  </div>

  <div class="values-grid">
    {
      values?.map((value) => (
        <div class="value-card">
          <img src={value.photo} alt={value.title} loading="lazy" />
          <div class="value-overlay">
            <div class="value-content">
              <span
                class="value-tag"
                style={`--tag-accent: ${value.accent || 'var(--color-red-accent)'}`}
              >
                {value.title}
              </span>
              <p class="value-description">{value.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .values-section {
    margin-bottom: 3rem;
  }

  .values-header {
    margin-bottom: 1.5rem;
  }

  .values-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-turquoise-panther);
    display: block;
    margin-bottom: 0.75rem;
  }

  .values-title {
    font-size: 1.75rem;
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-cream);
  }

  .values-accent {
    color: var(--color-icon-home);
    font-style: italic;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 220px;
    gap: 0.5rem;
  }

  .value-card {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: default;
  }

  .value-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .value-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      transparent 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .value-card:hover .value-overlay,
  .value-card:active .value-overlay {
    opacity: 1;
    cursor: pointer;
  }

  .value-card:hover img,
  .value-card:active img {
    transform: scale(1.06);
  }

  .value-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .value-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-cream);
    background: var(--tag-accent, rgba(255, 255, 255, 0.15));
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    width: fit-content;
    backdrop-filter: blur(4px);
  }

  .value-description {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-text-cream-alpha);
    line-height: 1.4;
    margin: 0;
  }

  @media (min-width: 481px) {
    .values-title {
      font-size: 2.25rem;
    }

    .values-grid {
      grid-auto-rows: 240px;
      gap: 0.75rem;
    }

    .value-description {
      font-size: 0.85rem;
    }
  }

  @media (min-width: 769px) {
    .values-grid {
      grid-template-columns: 1fr 1fr 1fr;
      grid-auto-rows: 280px;
    }
  }

  @media (min-width: 1024px) {
    .values-title {
      font-size: 2.5rem;
    }

    .values-grid {
      grid-auto-rows: 320px;
      gap: 1rem;
    }

    .value-overlay {
      padding: 1rem;
    }

    .value-description {
      font-size: 0.9rem;
    }
  }
</style>
