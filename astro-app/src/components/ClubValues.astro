---
import '../styles/section-backgrounds.css';
import { Image } from 'astro:assets';

interface ValueItem {
  photo: string;
  title: string;
  description: string;
  accent?: string;
  revealDirection?: 'up' | 'down' | 'left' | 'right' | 'none';
  revealSpeed?: number;
  revealDistance?: string;
  revealStagger?: string;
}

interface Props {
  values?: ValueItem[];
  /** Shared `u-bg-*` panel variants from section-backgrounds.css */
  bgVariant?: 'glow' | 'diagonal' | 'mesh' | 'salad';
}

const { values, bgVariant = 'salad' } = Astro.props;
---

<section class:list={['values-section', 'u-bg-panel', `u-bg-${bgVariant}`]}>
  <div class="values-header">
    <h2 class="values-title">
      Не просто тренировки — <span class="values-accent">добрая морось</span>
    </h2>
  </div>

  <div class="values-grid">
    {
      values?.map((value, index) => (
        <div
          class="value-card"
          data-value-card
          data-reveal-direction={value.revealDirection}
          data-reveal-speed={value.revealSpeed ? String(value.revealSpeed) : undefined}
          data-reveal-distance={value.revealDistance}
          style={`--reveal-index: ${index};${value.revealStagger ? ` --reveal-stagger: ${value.revealStagger};` : ''}`}
        >
          <Image src={value.photo} alt={value.title} loading="lazy" width={1200} height={800} />
          <div class="value-overlay">
            <div class="value-content">
              <span
                class="value-tag"
                style={`--tag-accent: ${value.accent || 'var(--color-red-accent)'}`}
              >
                {value.title}
              </span>
              <p class="value-description">{value.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import { initRevealOnView } from '../lib/revealOnView';

  initRevealOnView({
    selector: '[data-value-card]',
    visibleClass: 'value-card--visible',
    observedAttr: 'data-reveal-observed',
    rootMargin: '0px 0px -12% 0px',
    threshold: 0.12,
    defaultDirection: 'up',
    defaultDistance: '1.5rem',
    defaultDurationMs: 750,
  });
</script>

<style>
  .values-section {
    margin-bottom: 3rem;
  }

  .values-header {
    margin-bottom: 1.5rem;
  }

  .values-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-turquoise-panther);
    display: block;
    margin-bottom: 0.75rem;
  }

  .values-title {
    font-size: 1.75rem;
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-cream);
  }

  .values-accent {
    color: var(--color-icon-home);
    font-style: italic;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 280px;
    gap: 0.5rem;
  }

  .value-card {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: default;
    opacity: 0;
    transform: translate3d(var(--reveal-translate-x, 0px), var(--reveal-translate-y, 1.5rem), 0);
    transition:
      opacity var(--reveal-duration, 750ms) cubic-bezier(0.22, 1, 0.36, 1),
      transform var(--reveal-duration, 750ms) cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--reveal-index, 0) * var(--reveal-stagger, 0.12s));
  }

  .value-card--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .value-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .value-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      transparent 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .value-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (scripting: none) {
    .value-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .value-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .value-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-cream);
    background: var(--tag-accent, rgba(255, 255, 255, 0.15));
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    width: fit-content;
    backdrop-filter: blur(4px);
  }

  .value-description {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-cream-alpha);
    line-height: 1.4;
    margin: 0;
  }

  @media (min-width: 481px) {
    .values-title {
      font-size: 2.25rem;
    }

    .values-grid {
      grid-auto-rows: 300px;
      gap: 0.75rem;
    }
  }

  @media (min-width: 769px) {
    .values-grid {
      grid-template-columns: 1fr 1fr 1fr;
      grid-auto-rows: 320px;
    }
  }

  @media (min-width: 1024px) {
    .values-title {
      font-size: 2.5rem;
    }

    .values-grid {
      grid-auto-rows: 360px;
      gap: 1rem;
    }

    .value-overlay {
      padding: 1rem;
    }

    .value-description {
      font-size: 1rem;
    }
  }
</style>
