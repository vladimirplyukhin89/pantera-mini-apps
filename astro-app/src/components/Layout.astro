---
import { ClientRouter, fade } from 'astro:transitions';
import YandexMetrika from './YandexMetrika.astro';
import '../styles/variables.css';
import '../styles/fonts.css';

interface Props {
  title?: string;
}

const { title = 'Pantera Shop' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Pantera — клуб бокса" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images" />
    <meta name="generator" content={Astro.generator} />
    <YandexMetrika counterId={108433630} />

    <!-- View Transitions: клиентская навигация без полной перезагрузки для внутренних ссылок -->
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-container" transition:animate={fade({ duration: '0.22s' })}>
      <slot />
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: 'KabrioAbarth', sans-serif;
    font-size: 14px;
    line-height: 1.5;
  }

  @media (min-width: 481px) {
    html {
      font-size: 15px;
    }
  }

  @media (min-width: 1024px) {
    html {
      font-size: 16px;
    }
  }

  body {
    font-family: 'KabrioAbarth', sans-serif;
    background-color: var(--color-bg-dark);
    color: var(--color-text-cream);
    min-height: 100vh;
    padding-bottom: 70px;
  }

  .app-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 481px) {
    body {
      padding-bottom: 80px;
    }
  }

  @media (min-width: 1024px) {
    body {
      padding-bottom: 90px;
    }
  }
</style>
