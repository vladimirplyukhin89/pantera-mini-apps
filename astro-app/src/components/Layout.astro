---
// src/components/Layout.astro
// Базовый Layout для всех страниц
// Верхняя часть (---) - это секция для JavaScript/TypeScript
// Ниже - HTML разметка

import TelegramWebAppInit from './TelegramWebAppInit.astro';

interface Props {
  title?: string;
}

const { title = 'Pantera Shop' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Магазин футболок зала бокса Pantera" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Telegram WebApp SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
  </head>
  <body>
    <TelegramWebAppInit />
    <div class="app-container">
      <slot />
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-size: 14px;
    line-height: 1.5;
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    html {
      font-size: 15px;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    html {
      font-size: 16px;
    }
  }

  body {
    background-color: #ffffff;
    color: #1a1a1a;
    min-height: 100vh;
  }

  .app-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Стили для Telegram Mini App */
  body {
    /* Telegram WebApp автоматически устанавливает эти переменные */
    background-color: var(--tg-theme-bg-color, #ffffff);
    color: var(--tg-theme-text-color, #000000);
  }
</style>

