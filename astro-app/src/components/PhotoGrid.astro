---
import { Image } from 'astro:assets';

interface PhotoItem {
  src: string;
  alt: string;
  tag: string;
  variant?: 'tall' | 'wide';
}

interface Props {
  photos?: PhotoItem[];
}

// const defaultPhotos: PhotoItem[] = [
//   { src: '/images/jpg/01.jpg', alt: 'Pantera клуб', tag: 'Атмосфера', variant: 'tall' },
//   { src: '/images/jpg/03.jpg', alt: 'Тренировка', tag: 'Тренировки' },
//   { src: '/images/jpg/07.jpg', alt: 'В зале', tag: 'Дисциплина' },
//   { src: '/images/jpg/36.jpg', alt: 'Команда', tag: 'Команда', variant: 'wide' },
//   { src: '/images/jpg/09.jpg', alt: 'Спарринг', tag: 'Спарринги' },
//   { src: '/images/jpg/37.jpg', alt: 'Дух победы', tag: 'Дух победы', variant: 'tall' },
// ];

const { photos } = Astro.props;
---

<div class="photo-grid">
  {
    photos?.map((photo: PhotoItem) => (
      <div
        class:list={[
          'grid-item',
          { 'grid-item-tall': photo.variant === 'tall' },
          { 'grid-item-wide': photo.variant === 'wide' },
        ]}
      >
        <Image
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          width={1200}
          height={800}
        />
        <div class="grid-overlay">
          <span class="grid-tag">{photo.tag}</span>
        </div>
      </div>
    ))
  }
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 180px;
    gap: 0.5rem;
  }

  .grid-item {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: default;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .grid-item:hover .grid-overlay,
  .grid-item:active .grid-overlay {
    opacity: 1;
  }

  .grid-item:hover img,
  .grid-item:active img {
    transform: scale(1.05);
  }

  .grid-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-cream);
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
  }

  .grid-item-tall {
    grid-row: span 2;
  }

  .grid-item-wide {
    grid-column: span 2;
  }

  @media (min-width: 481px) {
    .photo-grid {
      grid-template-columns: 1fr 1fr 1fr;
      grid-auto-rows: 220px;
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .photo-grid {
      grid-auto-rows: 260px;
      gap: 1rem;
    }
  }
</style>
