---
import { ContactSocialIcon } from './ContactSocialIcon';

interface ContactItem {
  icon: string;
  label: string;
  value: string;
  href?: string;
}

interface Social {
  name: string;
  url: string;
  /** Fallback emoji/символ для сетей без React-иконки */
  icon?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  contacts?: ContactItem[];
  socials?: Social[];
  quote?: string;
}

const { title, subtitle, contacts, socials, quote } = Astro.props;
---

<section class="contact-section">
  <div class="contact-inner">
    <div class="contact-header">
      <h2 class="contact-title">{title}</h2>
      <p class="contact-subtitle">{subtitle}</p>
    </div>

    <div class="contact-grid">
      {
        contacts?.map((c) => (
          <div class="contact-card">
            <span class="contact-icon">{c.icon}</span>
            <div class="contact-card-body">
              <span class="contact-card-label">{c.label}</span>
              {c.href ? (
                <a href={c.href} class="contact-card-value contact-link">
                  {c.value}
                </a>
              ) : (
                <span class="contact-card-value">{c.value}</span>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <div class="socials-row">
      {
        socials?.map((s) => (
          <a
            href={s.url}
            class="social-link"
            data-social={s.name.toLowerCase()}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.name}
          >
            <ContactSocialIcon name={s.name} icon={s.icon} />
            <span class="social-name">{s.name}</span>
          </a>
        ))
      }
    </div>

    {quote && <p class="contact-quote">{quote}</p>}
  </div>
</section>

<style>
  .contact-section {
    margin-top: 2.1rem;
    border-radius: 1.5rem;
    overflow: hidden;
    background: var(--color-bg-purple);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .contact-inner {
    padding: 2rem 1.25rem;
  }

  .contact-header {
    margin-bottom: 1.75rem;
  }

  .contact-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-turquoise-panther);
    display: block;
    margin-bottom: 0.5rem;
  }

  .contact-title {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .contact-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-cream-alpha);
    line-height: 1.5;
    margin: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-bg-overlay-cream);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .contact-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .contact-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .contact-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-white);
  }

  .contact-card-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-cream);
    line-height: 1.4;
  }

  .contact-link {
    color: var(--color-text-cream);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .contact-link:hover {
    color: var(--color-turquoise-panther);
  }

  .socials-row {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 1.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 2px solid var(--_social-color, rgba(255, 255, 255, 0.1));
    border-radius: 2rem;
    text-decoration: none;
    color: var(--color-text-cream);
    font-size: 0.85rem;
    font-weight: 600;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .social-link:hover {
    background: color-mix(in srgb, var(--_social-color, #fff) 12%, transparent);
    border-color: var(--_social-color, rgba(255, 255, 255, 0.2));
    box-shadow: 0 0 12px color-mix(in srgb, var(--_social-color, transparent) 20%, transparent);
    transform: translateY(-2px);
  }

  .social-link[data-social='telegram'] {
    --_social-color: var(--color-accent-blue);
  }
  .social-link[data-social='vk'] {
    --_social-color: var(--color-turquoise-panther);
  }
  .social-link[data-social='insta'],
  .social-link[data-social='instagram'] {
    --_social-color: var(--color-icon-gallery);
  }
  .social-link[data-social='youtube'] {
    --_social-color: var(--color-red-accent);
  }
  .social-link[data-social='whatsapp'] {
    --_social-color: var(--color-icon-contacts);
  }
  .social-link[data-social='tiktok'] {
    --_social-color: var(--color-icon-home);
  }

  .social-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .social-link :global(.social-svg-icon) {
    display: block;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .contact-quote {
    text-align: center;
    font-size: 0.95rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-cream-alpha);
    line-height: 1.6;
    padding: 0 0.5rem;
    margin: 0;
    opacity: 0.7;
  }

  @media (min-width: 481px) {
    .contact-inner {
      padding: 2.5rem 1.5rem;
    }

    .contact-title {
      font-size: 2rem;
    }

    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 768px) {
    .social-link :global(.social-svg-icon) {
      width: 2rem;
      height: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .contact-inner {
      padding: 3rem 2rem;
    }

    .contact-title {
      font-size: 2.25rem;
    }

    .contact-quote {
      font-size: 1.05rem;
    }
  }
</style>
