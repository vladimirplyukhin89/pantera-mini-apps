---
// src/components/HeroSection.astro
// Hero секция с фоном (фото человека), текстом поверх и красным прямоугольником

import HeroAccent from './HeroAccent';

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Псс, тут тишки продают',
  description = 'Бац бац и мимо',
  ctaLink = '/catalog',
} = Astro.props;
---

<section class="hero-section">
  <!-- Overlay поверх фона -->
  <div class="hero-overlay"></div>

  <!-- Контент поверх изображения -->
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-description">{description}</p>
    </div>

     <div class="hero-accent" >
      <HeroAccent client:load linkTo={ctaLink} className="hero-icon" />
     </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background-image: url('/images/mini-app-example-man.jpeg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      var(--color-overlay-dark) 0%,
      var(--color-overlay-dark-strong) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 1.5rem 1rem 15vh;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .hero-text {
    flex: 1;
    color: var(--color-text-cream);
  }

  .hero-title {
    font-family: 'KabrioAbarth', sans-serif;
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 0.75rem; 
    color: var(--color-text-cream);
    text-shadow: 0 2px 4px var(--color-shadow-text);
  }

  .hero-description {
    font-family: 'KabrioAbarth', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 5px 0;
    color: var(--color-text-cream-alpha);
    text-shadow: 0 1px 2px var(--color-shadow-text-light);
  }

  /* Красный прямоугольник (акцентный элемент) */
  .hero-accent {
    width: 80px;
    height: 60px;
    background-color: var(--color-red-accent);
    flex-shrink: 0;
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5px;
    text-decoration: none;
    color: var(--color-white);
    transition: opacity 0.2s;
    cursor: pointer;
  }

  /* Hover эффекты только для устройств с курсором/тачпадом */
  @media (hover: hover) and (pointer: fine) {
    .hero-accent:hover {
      opacity: 1;
    }

    .hero-accent:hover :global(.hero-icon) {
      transform: translateX(10px);
    }
  }

  .hero-accent:active {
    opacity: 0.8;
  }

  :global(.hero-icon) {
    transition: transform 0.3s ease;
    width: 40px;
    height: 40px;
  }
  
  :global(.hero-icon svg) {
    width: 100%;
    height: 100%;
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .hero-content {
      padding: 2rem 1.5rem 15vh;
      gap: 1.5rem;
    }

    .hero-title {
      font-size: 2.75rem;
      font-weight: 900;
    }

    .hero-description {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .hero-accent {
      width: 10rem;
      height: 8rem;
    }
    
    :global(.hero-icon) {
      width: 60px;
      height: 60px;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .hero-content {
      padding: 2.5rem 2rem 15vh;
      gap: 2rem;
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 900;
    }

    .hero-description {
      font-size: 1.75rem;
      font-weight: 700;
    }

    .hero-accent {
      width: 14rem;
      height: 10rem;
    }
    
    :global(.hero-icon) {
      width: 100px;
      height: 100px;
    }

    .hero-section {
      background-repeat: repeat;
      background-size: auto;
    }
  }

    /* Большие экраны (от 1440px) */
  @media (min-width: 1440px) {
    .hero-content {
      max-width: 1440px;
      margin: 0 auto;
    }
  }
</style>

