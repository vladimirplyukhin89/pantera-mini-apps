---
import HeroAccent from './HeroAccent';

interface Props {
  title?: string;
  description?: string;
  ctaLink?: string;
  bgMobile?: string;
  bgDesktop?: string;
}

const {
  title,
  description = 'Тут ребзя бокс раздаёт',
  ctaLink = '/sportsmen',
  bgMobile,
  bgDesktop,
} = Astro.props;

---

<section class="hero-section" style={`--bg-mobile: url('${bgMobile}'); --bg-desktop: url('${bgDesktop}')`}>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-description">{description}</p>
    </div>

    <div class="hero-accent">
      <HeroAccent client:load linkTo={ctaLink} className="hero-icon" />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background-image: var(--bg-mobile);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      var(--color-overlay-dark) 0%,
      var(--color-overlay-dark-strong) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 1.5rem 1rem 15vh;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .hero-text {
    flex: 1;
    color: var(--color-text-cream);
  }

  .hero-title {
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--color-text-cream);
    text-shadow: 0 2px 4px var(--color-shadow-text);
  }

  .hero-description {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 5px 0;
    color: var(--color-text-cream-alpha);
    text-shadow: 0 1px 2px var(--color-shadow-text-light);
  }

  .hero-accent {
    width: 80px;
    height: 60px;
    background-color: var(--color-red-accent);
    flex-shrink: 0;
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5px;
    text-decoration: none;
    color: var(--color-white);
    transition: opacity 0.2s;
    cursor: pointer;
  }

  .hero-accent:hover,
  .hero-accent:active {
    opacity: 1;
  }

  .hero-accent:hover :global(.hero-icon),
  .hero-accent:active :global(.hero-icon) {
    transform: translateX(10px);
  }

  .hero-accent:active :global(.hero-icon) {
    color: var(--color-icon-home);
  }

  .hero-accent:active :global(.hero-icon svg) {
    color: var(--color-icon-home);
    fill: var(--color-icon-home);
  }

  :global(.hero-icon) {
    transition:
      transform 0.3s ease,
      color 0.3s ease;
    width: 40px;
    height: 40px;
  }

  :global(.hero-icon svg) {
    width: 100%;
    height: 100%;
    transition:
      color 0.3s ease,
      fill 0.3s ease;
  }

  @media (min-width: 481px) {
    .hero-content {
      padding: 2rem 1.5rem 15vh;
      gap: 1.5rem;
    }

    .hero-title {
      font-size: 2.75rem;
      font-weight: 900;
    }

    .hero-description {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .hero-accent {
      width: 10rem;
      height: 8rem;
    }

    :global(.hero-icon) {
      width: 60px;
      height: 60px;
    }
  }

  @media (min-width: 769px) {
    .hero-section {
      background-image: var(--bg-desktop);
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: 2.5rem 2rem 15vh;
      gap: 2rem;
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 900;
    }

    .hero-description {
      font-size: 1.75rem;
      font-weight: 700;
    }

    .hero-accent {
      width: 14rem;
      height: 10rem;
    }

    :global(.hero-icon) {
      width: 100px;
      height: 100px;
    }
  }

  @media (min-width: 1440px) {
    .hero-content {
      max-width: 1440px;
      margin: 0 auto;
    }
  }
</style>
