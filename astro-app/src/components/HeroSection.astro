---
// src/components/HeroSection.astro
// Hero секция с фоном (фото человека), текстом поверх и красным прямоугольником

interface Props {
  title?: string;
  description?: string;
  imageUrl?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Pantera Shop',
  description = 'Бац бац и мимо',
  imageUrl = '/images/mini-app-example-man.jpeg',
  ctaText = 'Перейти в каталог',
  ctaLink = '/catalog'
} = Astro.props;
---

<section class="hero-section">
  <!-- Фоновое изображение -->
  <div class="hero-background">
    <img src={imageUrl} alt="Hero background" class="hero-image" />
    <div class="hero-overlay"></div>
  </div>

  <!-- Контент поверх изображения -->
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-description">{description}</p>
    </div>

    <!-- Красный прямоугольник (акцентный элемент) -->
    <div class="hero-accent">
      <svg class="hero-arrow" width="100%" height="100%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.59 16.59L13.17 12L8.59 7.41L10 6L16 12L10 18L8.59 16.59Z" fill="white"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.5) 100%
    );
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding: 1.5rem 1rem 15vh;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
  }

  .hero-text {
    flex: 1;
    color: #ffffff;
    z-index: 4;
  }

  .hero-title {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-description {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  /* Красный прямоугольник (акцентный элемент) - мобильный */
  .hero-accent {
    width: 60px;
    height: 60px;
    background-color: #d84c4c; /* Красный цвет */
    flex-shrink: 0;
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5px;
  }

  .hero-arrow {
    width: 100%;
    height: 100%;
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .hero-content {
      padding: 2rem 1.5rem 15vh;
      gap: 1.5rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-description {
      font-size: 1rem;
    }

    .hero-accent {
      width: 10rem;
      height: 8rem;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .hero-content {
      padding: 2.5rem 2rem 15vh;
      gap: 2rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-description {
      font-size: 1.125rem;
    }

    .hero-accent {
      width: 14rem;
      height: 10rem;
    }
  }
</style>

