---
import { Image } from 'astro:assets';
import { FaCode } from 'react-icons/fa';

const isHomePage = Astro.url.pathname === '/';
---

<header data-astro-prefetch="viewport" class="header">
  <div class="header-content">
    {
      isHomePage ? (
        <Image
          src="/images/svg/white_logo.svg"
          alt="Logo Pantera"
          class="logo-image"
          fetchpriority="high"
          loading="eager"
          width={60}
          height={40}
        />
      ) : (
        <a href="/" class="logo-link" aria-label="На главную">
          <Image
            src="/images/svg/white_logo.svg"
            alt="Logo Pantera"
            class="logo-image"
            fetchpriority="high"
            loading="eager"
            width={60}
            height={40}
          />
        </a>
      )
    }
    <h1 class="title">Pantera</h1>
    <div class="header-version" title="Версия сайта 1.1">
      <FaCode className="code-icon" />
      <span class="version-text">версия 1.1</span>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-header-overlay);
    backdrop-filter: blur(2px);
    border-bottom: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .header-content {
    max-width: 100%;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .title {
    font-family: 'KabrioAbarth', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-cream);
    background-color: var(--color-bg-orange);
    line-height: 1;
    margin: 0;
  }

  .logo-image {
    display: block;
    object-fit: cover;
    fill: --color-bg-cream;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    text-decoration: none;
    min-width: 2.75rem;
    min-height: 2.75rem;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition:
      opacity 0.2s,
      transform 0.2s,
      filter 0.2s;
  }

  .header-version {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.55rem 0.3rem 0.45rem;
    border-radius: 999px;
    background: rgba(255, 248, 231, 0.12);
    border: 1px solid rgba(255, 248, 231, 0.22);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }

  .header-version :global(.code-icon) {
    display: block;
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
    color: var(--color-turquoise-panther);
    opacity: 0.95;
  }

  .version-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: var(--color-text-cream-alpha);
    line-height: 1;
    white-space: nowrap;
  }

  @media (hover: hover) and (pointer: fine) {
    .logo-link:hover {
      transform: scale(1.05);
      filter: brightness(1.08);
    }
  }

  .logo-link:active {
    transform: scale(1.05);
  }

  @media (min-width: 481px) {
    .header-content {
      padding: 1rem 1.5rem;
    }

    .title {
      font-size: 2rem;
      font-weight: 900;
    }

    .header-version {
      gap: 0.4rem;
      padding: 0.35rem 0.65rem 0.35rem 0.5rem;
    }

    .header-version :global(.code-icon) {
      width: 1.05rem;
      height: 1.05rem;
    }

    .version-text {
      font-size: 0.7rem;
    }
  }

  @media (min-width: 576px) {
    .logo-image {
      width: 70px;
      height: 50px;
    }
  }

  @media (min-width: 1024px) {
    .header-content {
      padding: 1.25rem 1.5rem;
      margin: 0 auto;
    }

    .title {
      font-size: 2.25rem;
      font-weight: 900;
    }
  }

  @media (min-width: 1440px) {
    .header-content {
      max-width: 1440px;
    }
  }
</style>
