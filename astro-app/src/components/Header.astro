---
// src/components/Header.astro
// Шапка сайта с логотипом и иконкой корзины

interface Props {
  cartItemsCount?: number;
}

const { 
  cartItemsCount = 0,
   } = Astro.props;
---

<header class="header">
  <div class="header-content">
    <img src='/favicon.svg' alt="Logo" class="logo-image" />
    <h1 class="title">Pantera</h1>
    
    <a href="/cart" class="cart-link">
      <svg class="cart-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 18C5.9 18 5.01 18.9 5.01 20C5.01 21.1 5.9 22 7 22C8.1 22 9 21.1 9 20C9 18.9 8.1 18 7 18ZM1 2V4H3L6.6 11.59L5.25 14.04C5.09 14.32 5 14.65 5 15C5 16.1 5.9 17 7 17H19V15H7.42C7.28 15 7.17 14.89 7.17 14.75L7.2 14.63L8.1 13H15.55C16.3 13 16.96 12.59 17.3 11.97L20.88 5.48C20.96 5.34 21 5.17 21 5C21 4.45 20.55 4 20 4H5.21L4.27 2H1ZM17 18C15.9 18 15.01 18.9 15.01 20C15.01 21.1 15.9 22 17 22C18.1 22 19 21.1 19 20C19 18.9 18.1 18 17 18Z" fill="currentColor"/>
      </svg>
      {cartItemsCount > 0 && (
        <span class="cart-badge">{cartItemsCount}</span>
      )}
    </a>
  </div>
</header>

<style>
  .header {
    background-color: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(2px);
    border-bottom: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .header-content {
    max-width: 100%;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--tg-theme-text-color, #ffffff);
    margin: 0;
  }

  .logo-image {
    width: 32px;
    height: 32px;
    object-fit: cover;
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .header-content {
      padding: 1rem 1.5rem;
    }

    .title {
      font-size: 1.5rem;
    }

    .logo-image {
      width: 40px;
      height: 40px;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .header-content {
      padding: 1.25rem 2rem;
      max-width: 1280px;
      margin: 0 auto;
    }

    .title {
      font-size: 1.75rem;
    }

    .logo-image {
      width: 48px;
      height: 48px;
    }
  }

  .cart-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tg-theme-text-color, #ffffff);
    text-decoration: none;
    padding: 0.5rem;
  }

  .cart-icon {
    width: 24px;
    height: 24px;
  }

  .cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    background-color: var(--tg-theme-button-color, #3390ec);
    color: var(--tg-theme-button-text-color, #ffffff);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }
</style>

