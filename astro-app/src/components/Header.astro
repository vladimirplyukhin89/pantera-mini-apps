---
// src/components/Header.astro
// Шапка сайта с логотипом и иконкой корзины
import { Image } from 'astro:assets';
import CartIcon from './CartIcon';

// Props больше не нужны, CartIcon сам получает количество товаров

const isHomePage = Astro.url.pathname === '/';
---

<header class="header">
  <div class="header-content">
    {isHomePage ? (
      <Image 
        src='/images/svg/white_logo.svg' 
        alt="Logo" 
        class="logo-image"
        fetchpriority="high"
        loading="eager"
        width={60}
        height={40}
      />
    ) : (
      <a href="/" class="logo-link" aria-label="На главную">
        <Image 
          src='/images/svg/white_logo.svg' 
          alt="Logo" 
          class="logo-image"
          fetchpriority="high"
          loading="eager"
          width={60}
          height={40}
        />
      </a>
    )}
    <h1 class="title">Pantera Shop</h1>
    
    <a href="/cart" class="cart-link">
      <CartIcon client:load className="cart-icon" size={24} />
    </a>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-header-overlay);
    backdrop-filter: blur(2px);
    border-bottom: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .header-content {
    max-width: 100%;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .title {
    font-family: 'KabrioAbarth', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--tg-theme-text-color, var(--color-text-cream));
    background-color: var(--color-bg-orange);
    line-height: 1;
    margin: 0;
  }

  .logo-image {
    object-fit: cover;
    fill: --color-bg-cream;
  }

  .logo-link {
    display: inline-block;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  /* Hover эффекты только для устройств с курсором/тачпадом */
  @media (hover: hover) and (pointer: fine) {
    .logo-link:hover {
      opacity: 0.8;
      transform: scale(1.05);
    }
  }

  .logo-link:active {
    transform: scale(1.05);
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .header-content {
      padding: 1rem 1.5rem;
    }

    .title {
      font-size: 2rem;
      font-weight: 900;
    }
  }

  @media (min-width: 576px) {
    .logo-image {
      width: 70px;
      height: 50px;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .header-content {
      padding: 1.25rem 1.5rem;
      margin: 0 auto;
    }

    .title {
      font-size: 2.25rem;
      font-weight: 900;
    }
  }

  .cart-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tg-theme-text-color, var(--color-text-cream));
    text-decoration: none;
    padding: 0.5rem;
  }

  :global(.cart-icon) {
    width: 24px;
    height: 24px;
    transition: color 0.2s, transform 0.2s;
  }

  .cart-link {
    color: var(--color-text-cream);
  }

  /* Hover эффекты только для устройств с курсором/тачпадом */
  @media (hover: hover) and (pointer: fine) {
    :global(.cart-link:hover .cart-icon, .cart-link:active .cart-icon) {
      color: var(--color-icon-fire);
      transform: scale(1.1);

    }
  }

  .cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    background-color: var(--tg-theme-button-color, var(--color-accent-blue));
    color: var(--tg-theme-button-text-color, var(--color-white));
    font-size: 12px;
    font-weight: 600;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .cart-badge {
      font-size: 14px;
      width: 20px;
      height: 20px;
    }
  }

  @media (min-width: 1440px) {
    .header-content  {
      max-width: 1440px;
    }
  }
</style>

