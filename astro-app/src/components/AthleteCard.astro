---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  photo?: string;
  label?: string;
  name?: string;
  quote?: string;
  stats?: Stat[];
  badge?: string;
}

const { photo, label, name, quote, stats, badge } = Astro.props;
---

<div class="athlete-card">
  <div class="athlete-photo">
    <img src={photo} alt={name} loading="lazy" />
    <div class="athlete-gradient"></div>
  </div>
  <div class="athlete-info">
    <div class="athlete-label">{label}</div>
    <h2 class="athlete-name">{name}</h2>
    <p class="athlete-quote">{quote}</p>
    <div class="athlete-stats">
      {
        stats?.map((stat, i) => (
          <>
            {i > 0 && <div class="stat-divider" />}
            <div class="stat">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          </>
        ))
      }
    </div>
    {badge && <div class="athlete-badge">{badge}</div>}
  </div>
</div>

<style>
  .athlete-card {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .athlete-photo {
    position: relative;
    width: 100%;
    height: 320px;
  }

  .athlete-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .athlete-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to top, #111 0%, transparent 100%);
  }

  .athlete-info {
    padding: 0 1.5rem 1.75rem;
    margin-top: -3rem;
    position: relative;
    z-index: 1;
  }

  .athlete-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-turquoise-panther);
    margin-bottom: 0.5rem;
  }

  .athlete-name {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .athlete-quote {
    font-size: 1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-cream-alpha);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-red-accent);
  }

  .athlete-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--color-text-cream);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-gray);
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.1);
  }

  .athlete-badge {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-gray);
    background: rgba(255, 255, 255, 0.04);
    border: 1px dashed rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    text-align: center;
  }

  @media (min-width: 481px) {
    .athlete-photo {
      height: 400px;
    }

    .athlete-name {
      font-size: 2rem;
    }

    .athlete-stats {
      gap: 2rem;
    }

    .stat-value {
      font-size: 2rem;
    }
  }

  @media (min-width: 769px) {
    .athlete-label {
      font-size: 1.1rem;
      margin-bottom: auto;
    }
  }

  @media (min-width: 1024px) {
    .athlete-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .athlete-photo {
      height: 100%;
      min-height: 400px;
      max-height: 600px;
    }

    .athlete-gradient {
      height: 100%;
    }

    .athlete-info {
      margin-top: 0;
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }
</style>
