---
// src/components/BottomBar.astro
// Нижняя навигационная панель

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

// Определяем активную страницу
const isActive = (path: string) => currentPath === path;
---

<nav class="bottom-bar">
  <a href="/" class={`bottom-bar-item ${isActive('/') ? 'active' : ''}`}>
    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 20V14H14V20H19V12H22L12 3L2 12H5V20H10Z" fill="currentColor"/>
    </svg>
    <span class="label">Главная</span>
  </a>

  <a href="/catalog" class={`bottom-bar-item ${isActive('/catalog') ? 'active' : ''}`}>
    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 6H2V20C2 21.1 2.9 22 4 22H18V20H4V6ZM20 2H8C6.9 2 6 2.9 6 4V16C6 17.1 6.9 18 8 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2ZM20 16H8V4H20V16Z" fill="currentColor"/>
    </svg>
    <span class="label">Каталог</span>
  </a>

  <a href="/cart" class={`bottom-bar-item ${isActive('/cart') ? 'active' : ''}`}>
    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 18C5.9 18 5.01 18.9 5.01 20C5.01 21.1 5.9 22 7 22C8.1 22 9 21.1 9 20C9 18.9 8.1 18 7 18ZM1 2V4H3L6.6 11.59L5.25 14.04C5.09 14.32 5 14.65 5 15C5 16.1 5.9 17 7 17H19V15H7.42C7.28 15 7.17 14.89 7.17 14.75L7.2 14.63L8.1 13H15.55C16.3 13 16.96 12.59 17.3 11.97L20.88 5.48C20.96 5.34 21 5.17 21 5C21 4.45 20.55 4 20 4H5.21L4.27 2H1ZM17 18C15.9 18 15.01 18.9 15.01 20C15.01 21.1 15.9 22 17 22C18.1 22 19 21.1 19 20C19 18.9 18.1 18 17 18Z" fill="currentColor"/>
    </svg>
    <span class="label">Корзина</span>
  </a>

  <a href="/contacts" class={`bottom-bar-item ${isActive('/contacts') ? 'active' : ''}`}>
    <svg class="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 4H4C2.9 4 2.01 4.9 2.01 6L2 18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4ZM20 8L12 13L4 8V6L12 11L20 6V8Z" fill="currentColor"/>
    </svg>
    <span class="label">Контакты</span>
  </a>
</nav>

<style>
  .bottom-bar {
    background-color: var(--tg-theme-bg-color, #ffffff);
    border-top: 1px solid var(--tg-theme-hint-color, #e0e0e0);
    width: 90%;
    position: fixed;
    bottom: 3%;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 2rem;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0.5rem 0;
    z-index: 100;
    /* Безопасная зона для iOS */
    padding-bottom: env(safe-area-inset-bottom, 0.5rem);
  }

  .bottom-bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--tg-theme-hint-color, #999999);
    padding: 0.5rem 0.75rem;
    transition: color 0.2s;
    flex: 1;
    max-width: 25%;
  }

  .bottom-bar-item.active {
    color: var(--tg-theme-button-color, #3390ec);
  }

  .bottom-bar-item .icon {
    width: 22px;
    height: 22px;
    margin-bottom: 0.25rem;
  }

  .bottom-bar-item .label {
    font-size: 0.7rem;
    font-weight: 500;
  }

  /* Планшеты (от 481px) */
  @media (min-width: 481px) {
    .bottom-bar {
      width: 85%;
      bottom: 4%;
      padding: 0.625rem 0;
    }

    .bottom-bar-item {
      padding: 0.5rem 1rem;
    }

    .bottom-bar-item .icon {
      width: 24px;
      height: 24px;
    }

    .bottom-bar-item .label {
      font-size: 0.75rem;
    }
  }

  /* Десктоп (от 1024px) */
  @media (min-width: 1024px) {
    .bottom-bar {
      width: 600px;
      bottom: 2rem;
      padding: 0.75rem 0;
    }

    .bottom-bar-item .icon {
      width: 26px;
      height: 26px;
    }

    .bottom-bar-item .label {
      font-size: 0.875rem;
    }
  }

  /* Отступ для контента, чтобы не перекрывался bottom bar - мобильный */
  body {
    padding-bottom: 70px;
  }

  /* Планшеты */
  @media (min-width: 481px) {
    body {
      padding-bottom: 80px;
    }
  }

  /* Десктоп */
  @media (min-width: 1024px) {
    body {
      padding-bottom: 90px;
    }
  }
</style>

