---
// src/components/TelegramWebAppInit.astro
// Инициализация и проверка Telegram WebApp SDK
// Этот компонент можно использовать для проверки что SDK загружен

---

<script>
  // Проверяем что Telegram WebApp SDK загружен
  // Этот скрипт выполнится на клиенте
  
  // Ждем загрузки скрипта Telegram WebApp SDK
  if (typeof window !== 'undefined') {
    // Проверка после загрузки страницы
    window.addEventListener('DOMContentLoaded', () => {
      // Проверяем наличие Telegram WebApp объекта
      if (window.Telegram && window.Telegram.WebApp) {
        console.log('✅ Telegram WebApp SDK загружен');
        console.log('WebApp:', window.Telegram.WebApp);
        console.log('Версия:', window.Telegram.WebApp.version);
        console.log('Платформа:', window.Telegram.WebApp.platform);
        console.log('Инициализирован:', window.Telegram.WebApp.isExpanded);
        
        // Инициализация (если нужно)
        window.Telegram.WebApp.ready();
        
        // Можно расширить на весь экран
        // window.Telegram.WebApp.expand();
      } else {
        console.warn('⚠️ Telegram WebApp SDK не найден (это нормально в браузере)');
        console.log('SDK работает только внутри Telegram Mini App');
      }
    });
  }
</script>

